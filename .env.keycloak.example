# =============================================================================
# Huella Latam — Keycloak DEV environment (OPTIONAL)
# =============================================================================
# Consumed by compose/keycloak-db.yaml + compose/keycloak.dev.yaml. Counterpart
# to .env.prod.keycloak (production), mirroring the app's own
# .env.dockercompose / .env.prod.dockercompose split.
#
# You usually DON'T need this file. With the bundled DB, the dev overlay runs
# with ZERO configuration — admin/admin, host localhost:18080, and DB
# keycloak/keycloak are baked into compose/keycloak.dev.yaml. Bring it up with
# no --env-file at all:
#   docker compose --project-directory . \
#     -f compose/keycloak-db.yaml -f compose/keycloak.dev.yaml up -d
#
# Create this file ONLY to point dev Keycloak at an EXTERNAL Postgres (or to
# override the bundled DB defaults):
#   cp .env.keycloak.example .env.keycloak     # then set the KC_DB_* vars below
#   docker compose --project-directory . -f compose/keycloak.dev.yaml \
#     --env-file .env.keycloak up -d
# `.env.keycloak` is gitignored; this template is committed.
#
# Baked into compose/keycloak.dev.yaml (NOT set here — dev only, not secret):
#   KC_HOSTNAME=http://localhost:18080, KC_BOOTSTRAP_ADMIN_USERNAME/PASSWORD=admin.
# For the PRODUCTION Keycloak env (TLS, hostname, bootstrap admin, strong DB
# credentials), see .env.prod.keycloak.example.
# =============================================================================

# --- Database ---
# Vendor (build-time option; the repo standard is postgres).
KC_DB=postgres
# Full JDBC URL override — leave empty to build it from the components below.
# Set it only for extras the components can't express (e.g. ?sslmode=require).
KC_DB_URL=
# Bundled DB: keep these as-is (they match compose/keycloak-db.yaml's defaults).
# External Postgres: change KC_DB_URL_HOST (+ port/database) and the credentials.
# HOST and PORT are decided together by HOW Keycloak reaches the DB:
#   • bundled DB via the docker network → keycloak-db + 5432 (the container's
#     internal port — the defaults below)
#   • a container reached through the host's IP → the host's static IP + the
#     port that container PUBLISHES on the host
#   • an external/remote server → its DNS/IP + the port it listens on
# NEVER localhost — inside the container that is Keycloak itself, not your
# machine. See docs/infrastructure/KeycloakSetup.md → "External database —
# choosing KC_DB_URL_HOST".
# (The bundled DB also publishes a fixed 127.0.0.1:15432 on the host — that is
# only for YOU to inspect it with psql; Keycloak never uses it.)
KC_DB_URL_HOST=keycloak-db
KC_DB_URL_PORT=5432
KC_DB_URL_DATABASE=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak
