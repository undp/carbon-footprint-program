# =============================================================================
# Huella Latam — Keycloak DEV environment (OPTIONAL)
# =============================================================================
# Consumed by compose/keycloak-db.yaml + compose/keycloak.dev.yaml. Counterpart
# to .env.prod.keycloak (production), mirroring the app's own
# .env.dockercompose / .env.prod.dockercompose split.
#
# Usually unnecessary: the bundled dev overlay uses admin/admin, localhost:18080,
# keycloak/keycloak by default (baked into compose/keycloak.dev.yaml). Bring it up
# with no --env-file at all:
#   docker compose --project-directory . \
#     -f compose/keycloak-db.yaml -f compose/keycloak.dev.yaml up -d
#
# Create this file ONLY to point dev Keycloak at an EXTERNAL Postgres (or to
# override the bundled DB defaults):
#   cp .env.keycloak.example .env.keycloak     # then set the KC_DB_* vars below
#   docker compose --project-directory . -f compose/keycloak.dev.yaml \
#     --env-file .env.keycloak up -d
# `.env.keycloak` is gitignored; this template is committed.
#
# Baked into compose/keycloak.dev.yaml (NOT set here — dev only, not secret):
#   KC_BOOTSTRAP_ADMIN_USERNAME/PASSWORD=admin. KC_HOSTNAME also defaults to
#   http://localhost:18080 there, but is env-driven — override it below (see the
#   Hostname section) to reach the app from another device.
# For the PRODUCTION Keycloak env (TLS, hostname, bootstrap admin, strong DB
# credentials), see .env.prod.keycloak.example.
# =============================================================================

# --- Database ---
# Vendor (build-time option; the repo standard is postgres).
KC_DB=postgres
# Full JDBC URL override — leave empty to build it from the components below.
# Set it only for extras the components can't express (e.g. ?sslmode=require).
# If you set it, it must be a pgJDBC URL, NOT libpq/Prisma form:
#   • MUST start with jdbc:  → jdbc:postgresql://host:port/db  (a bare
#     postgresql://… fails with "Driver does not support the provided URL")
#   • NO credentials in the URL (no user:pass@host) — use the KC_DB_* vars below
#   • schema param is ?currentSchema=… (NOT ?schema=…) — or just use KC_DB_SCHEMA
# See docs/infrastructure/KeycloakSetup.md → "Overriding KC_DB_URL".
KC_DB_URL=
# Bundled DB: keep as-is (matches compose/keycloak-db.yaml). External Postgres:
# point KC_DB_URL_HOST/PORT at where Keycloak reaches the DB (never localhost —
# inside the container that's Keycloak itself) and set the credentials. Host/port
# guide: docs/infrastructure/KeycloakSetup.md. (The bundled DB also publishes
# 127.0.0.1:15432 for psql inspection only.)
KC_DB_URL_HOST=keycloak-db
KC_DB_URL_PORT=5432
KC_DB_URL_DATABASE=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak
# Postgres schema (namespace) for Keycloak's tables. Defaults to `public`; set
# only for a pre-created shared schema.
KC_DB_SCHEMA=public

# --- Hostname ---
# Browser-facing public URL Keycloak is reachable at → becomes the token issuer
# (`iss`). Defaults to http://localhost:18080 (baked into compose/keycloak.dev.yaml),
# so leave it as-is for the standard localhost dev flow. It MUST match
# VITE_OIDC_ISSUER / JWKS_ISSUER in the app env — the browser posts the token
# request to this host and the web CSP is built from VITE_OIDC_ISSUER, so a
# mismatch is blocked. Override it to your machine's LAN IP (e.g.
# http://<lan-ip>:18080) to reach the app from another device on the network.
KC_HOSTNAME=http://localhost:18080
