{
  "name": "huella-latam",
  "version": "0.0.0",
  "description": "Huella Latam monorepo",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "build": "turbo run build",
    "start": "turbo run start",
    "start:api": "turbo run start --filter=api",
    "start:web": "turbo run start --filter=web",
    "test": "pnpm test:base && pnpm test:storage-azure && pnpm test:storage-minio",
    "test:base": "turbo run test:base --filter=api",
    "test:storage-azure": "turbo run test:storage-azure --filter=api",
    "test:storage-minio": "turbo run test:storage-minio --filter=api",
    "test:verify-storage-manifest": "turbo run test:verify-storage-manifest --filter=api",
    "lint": "turbo run lint -- --max-warnings=0",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean",
    "db:restore": "turbo run db:restore --filter=@repo/database && turbo run seed --filter=@repo/seed",
    "db:seed": "turbo run seed --filter=@repo/seed",
    "db:promote-superadmin": "pnpm --filter=@repo/database promote-superadmin"
  },
  "devDependencies": {
    "cpy-cli": "^7.0.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.10.3"
  }
}
