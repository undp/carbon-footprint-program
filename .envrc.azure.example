# =============================================================================
# Azure Entra ID — local development env (direnv)
# =============================================================================
# The app is a generic OIDC client + JWKS validator and knows NOTHING about
# Azure. This file is the Azure "adapter": you fill in a handful of RAW tenant
# values once, and every issuer / JWKS URL / scope is DERIVED below by shell
# interpolation — so you never have to remember Entra's URL formats, and the
# application code never has to either.
#
# Usage:
#   cp .envrc.azure.example .envrc   # then fill in the RAW VALUES block
#   direnv allow
#
# For Keycloak or any other IdP, start from `.envrc.template` instead.
# Full guide: docs/infrastructure/AzureAuthenticationSetup.md
# =============================================================================

# ── RAW VALUES — the only things you edit ────────────────────────────────────
# AZURE_TENANT_TYPE: "external" (CIAM / ciamlogin.com) or "organizational" (Azure AD)
export AZURE_TENANT_TYPE="external"
export AZURE_TENANT_ID=""            # Tenant ID (GUID)
export AZURE_TENANT_SUBDOMAIN=""     # Tenant subdomain (only for AZURE_TENANT_TYPE="external")
export AZURE_API_CLIENT_ID=""        # API App Registration ID (becomes the token audience)
export AZURE_FRONT_CLIENT_ID=""      # Frontend (SPA) App Registration ID

# ── DERIVED — do not edit; computed from the raw values above ────────────────
# CIAM quirk (external tenants): the FRONTEND discovery/authority uses the tenant
# SUBDOMAIN host, but the token `iss` and the JWKS endpoint the BACKEND validates
# use the tenant-GUID host. Organizational tenants use the same
# login.microsoftonline.com host for everything.
if [ "$AZURE_TENANT_TYPE" = "organizational" ]; then
  _FRONT_ISSUER="https://login.microsoftonline.com/${AZURE_TENANT_ID}/v2.0"
  _TOKEN_ISSUER="$_FRONT_ISSUER"
  _JWKS_URI="https://login.microsoftonline.com/${AZURE_TENANT_ID}/discovery/v2.0/keys"
else
  _FRONT_ISSUER="https://${AZURE_TENANT_SUBDOMAIN}.ciamlogin.com/${AZURE_TENANT_ID}/v2.0"
  _TOKEN_ISSUER="https://${AZURE_TENANT_ID}.ciamlogin.com/${AZURE_TENANT_ID}/v2.0"
  _JWKS_URI="https://${AZURE_TENANT_SUBDOMAIN}.ciamlogin.com/${AZURE_TENANT_ID}/discovery/v2.0/keys"
fi

# Backend — the API validates the access token against these JWKS_* values as-is.
export AUTH_PROVIDER="jwks"
export JWKS_ISSUER="$_TOKEN_ISSUER"   # token `iss` (GUID host for CIAM)
export JWKS_URI="$_JWKS_URI"          # JWKS endpoint (subdomain host for CIAM)
export JWKS_AUDIENCE="$AZURE_API_CLIENT_ID"   # Entra v2.0 `aud` is the bare API client-id GUID
# export JWKS_REQUIRED_SCOPE="access_as_user" # default; uncomment only to override

# Frontend (build-time) — the OIDC authority host used for discovery; the API
# scope is appended so the access token's `aud` is the API.
export VITE_OIDC_ISSUER="$_FRONT_ISSUER"
export VITE_OIDC_CLIENT_ID="$AZURE_FRONT_CLIENT_ID"
export VITE_OIDC_SCOPES="openid profile email offline_access api://${AZURE_API_CLIENT_ID}/access_as_user"
# VITE_OIDC_REDIRECT_URI / VITE_OIDC_POST_LOGOUT_REDIRECT_URI are derived from
# VITE_FRONT_BASE_URL in the Web section below (bash evaluates top to bottom,
# so the derivation must come after that variable is defined).

# ── Storage (Azure Blob) ─────────────────────────────────────────────────────
# Run `az login` so DefaultAzureCredential can authenticate. Leave the account
# name empty to disable file upload/download locally.
export STORAGE_PROVIDER="azure_blob_storage"
export AZURE_STORAGE_ACCOUNT_NAME=""    # Storage account name (e.g., "stj7k8m9n0p1")
export AZURE_STORAGE_CONTAINER_NAME=""  # Blob container name. Defaults to "files" if empty.

# ── Database ─────────────────────────────────────────────────────────────────
export DATABASE_URL=""  # PostgreSQL connection string, e.g., postgresql://user:password@localhost:5432/dbname

# ── API ──────────────────────────────────────────────────────────────────────
export APP_VERSION=""
export LOG_LEVEL=""     # Options: debug, info, warn, error
export NODE_ENV=""      # Options: development, production, test
# export SUPERADMIN_EMAIL=""   # Email promoted via `pnpm db:promote-superadmin`

# ── Chatbot (optional AI feature — DPG optionality) ──────────────────────────
# Off by default platform-wide. This Azure example enables it end-to-end. To
# run without AI, set CHATBOT_ENABLED="false" and leave the rest blank.
export CHATBOT_ENABLED="true"
export LLM_PROVIDER="azure-openai"        # "mock" (no cloud) is rejected in production when enabled
export AZURE_OPENAI_ENDPOINT=""           # e.g. https://<resource>.openai.azure.com
export AZURE_OPENAI_DEPLOYMENT_NAME=""    # your chat model deployment name
export COOKIE_SECRET=""                   # long random string — signs the anonymous session cookie

# ── Web ──────────────────────────────────────────────────────────────────────
export VITE_APP_VERSION=""
export VITE_CHATBOT_ENABLED="true"   # show the chatbot widget (mirror of CHATBOT_ENABLED)
export VITE_API_BASE_URL=""    # URL for the API (e.g. http://localhost:8080/api)
export VITE_FRONT_BASE_URL=""  # browser-reachable web URL (used to derive the OIDC redirect URIs below)
# Both OPTIONAL — empty and undeclared behave the same: the app falls back to
# the serving origin. The ${VAR:+...} guard keeps VITE_OIDC_REDIRECT_URI empty
# when VITE_FRONT_BASE_URL is empty (otherwise the literal "/auth/callback"
# would skip the fallback and fail the IdP's match).
export VITE_OIDC_REDIRECT_URI="${VITE_FRONT_BASE_URL:+${VITE_FRONT_BASE_URL}/auth/callback}"
export VITE_OIDC_POST_LOGOUT_REDIRECT_URI="${VITE_FRONT_BASE_URL}"
export VITE_IS_DEMO_APP="false"
