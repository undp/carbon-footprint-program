		timestamptz updated_at  ""  
		BIGINT created_by FK ""  
		BIGINT updated_by FK ""  
		%% UNIQUE(user_id, country_id, system_role_id)
	}

	%% ============================================================
	%% 🟧 Inventory & calculation (9)
	%% ============================================================

	%% organization & organization_branch will be NULL when user does not belong to any org.
	carbon_inventory {
		BIGINT id PK ""
		string name "NULLABLE"
		BIGINT organization_id FK "NULLABLE"
		BIGINT organization_branch_id FK "NULLABLE"
		JSONB organization_data "NULLABLE"
		int year "NULLABLE"
		enum status "DRAFT | SUBMITTED | VERIFIED | DELETED"
		enum usage_mode "SIMPLIFIED | EXPERT"
		BIGINT methodology_version_id FK "NULLABLE"
		BIGINT preselected_nodes_id FK "NULLABLE"
		boolean is_editable ""
		timestamptz created_at  ""
		timestamptz updated_at  ""
		BIGINT created_by FK "NULLABLE"
		BIGINT updated_by FK "NULLABLE"
	}

	%% A "line" represents what is being measured (subcategory) for a given inventory.
	%% We do not store quantities/factors/selections here. It's the anchor.
	carbon_inventory_line {
		BIGINT id PK ""
		BIGINT carbon_inventory_id FK "carbon_inventory(id)"
		BIGINT subcategory_id FK "subcategory(id)"
		enum status "ACTIVE | OUTDATED | DELETED"
		timestamptz created_at  ""
		timestamptz updated_at  ""
		BIGINT created_by FK ""
		BIGINT updated_by FK ""
	}

	carbon_inventory_line_input {
		BIGINT id PK ""
		BIGINT line_id FK "carbon_inventory_line(id)"
		enum input_type "SIMPLIFIED|EXPERT|DIRECT"
		
		%% the "dimension selections" (more on dimension standardization in section 4)
		BIGINT selection_1_id FK "NULLABLE, emission_factor_dimension_value(id)"
		BIGINT selection_2_id FK "NULLABLE, emission_factor_dimension_value(id)"
		
		numeric quantity "NULLABLE"
		BIGINT measurement_unit_id FK "NULLABLE, measurement_unit(id)"
		
		%% For DIRECT mode:
		numeric direct_total_emissions "NULLABLE"
		
		%% For EXPERT mode:
		numeric manual_factor "NULLABLE"
		string manual_factor_source "NULLABLE"
		BIGINT manual_factor_rate_unit_id FK "NULLABLE, rate_measurement_unit(id)"

		text comment "NULLABLE"
		boolean is_active ""
		timestamptz created_at  ""  
		timestamptz updated_at  ""  
		BIGINT created_by FK ""  
		BIGINT updated_by FK ""  
		%% Enforce only one active input per line: UNIQUE(line_id) WHERE is_active = true
	}

	%% This stores "what factor did we use, after conversions, and why" so results are reproducible.
	carbon_inventory_line_factor {
		BIGINT id PK ""
		BIGINT line_input_id FK "carbon_inventory_line_input(id)"

		%% chosen factor: either from catalog (simplified) or null for expert/direct
		BIGINT emission_factor_id FK "NULLABLE, emission_factor(id)"

		%% normalized factor actually used in the computation (post-conversion)
		%% REQUIRED: Must always be present for result reproducibility
		numeric applied_factor_value "REQUIRED"
		BIGINT applied_factor_rate_unit_id FK "rate_measurement_unit(id)"
		string applied_factor_source "NULLABLE"

		%% optionally store a JSON blob explaining conversion steps for auditability
		JSONB derivation_details "NULLABLE"

		timestamptz created_at  ""  
		timestamptz updated_at  ""  
		BIGINT created_by FK ""  
		BIGINT updated_by FK ""  
		%% Enforce 1 factor row per input: UNIQUE(line_input_id)
	}

	carbon_inventory_line_result {
		BIGINT id PK ""
		BIGINT line_input_id FK "carbon_inventory_line_input(id)"
		numeric total_emissions ""
		%% optionally store breakdown: per-gas, CO2e, etc.
		JSONB result_details "NULLABLE"
		timestamptz calculated_at ""
		timestamptz created_at  ""
		timestamptz updated_at  ""
		BIGINT created_by FK "NULLABLE"
		BIGINT updated_by FK "NULLABLE"
		%% Ensure 1 result per input: UNIQUE(line_input_id)
	}

	reduction_suggestion_catalog {
		BIGINT id PK ""  
		BIGINT emission_factor_id FK ""  
		text content  ""  
		timestamptz created_at  ""  
		timestamptz updated_at  ""  
		BIGINT created_by FK ""  
		BIGINT updated_by FK ""  
	}

	%% We plan to create these suggestion with AI
	reduction_personalized_suggestion {
		BIGINT id PK ""  
		BIGINT carbon_inventory_line_id FK ""  
		BIGINT reduction_suggestion_catalog_id FK ""
		text content  ""  
		timestamptz created_at  ""  
		timestamptz updated_at  ""  
		BIGINT created_by FK ""  
		BIGINT updated_by FK ""  
	}

	reduction_project {
		BIGINT id PK ""  
		BIGINT carbon_inventory_id FK ""  
		BIGINT organization_branch_id FK "NULLABLE"
		string project_name  ""  
		date implementation_date  ""  
		string description  ""  
		string emission_source_subcategory  ""  
		BIGINT global_warming_potential_id FK ""  
		float co2e_reduction  ""  
		string reported_years  ""  
		timestamptz created_at  ""  
		timestamptz updated_at  ""  
		BIGINT created_by FK ""  
		BIGINT updated_by FK ""  
	}

	neutralization_plan {
		BIGINT id PK ""  
		BIGINT carbon_inventory_id FK ""  
		string name  ""  
		string description  ""  
		float co2e_neutralized  ""  
		int year  ""  
		timestamptz created_at  ""  
		timestamptz updated_at  ""  
		BIGINT created_by FK ""  
		BIGINT updated_by FK ""  
	}

	%% ============================================================
	%% 🟥 Submissions & recognition (7)
	%% ============================================================
	
	%% Read the docs about the submissions model design here: https://www.notion.so/Modelo-E-R-para-Submissions-2d318d2c8901805ab8f9eed2a9d9d702?source=copy_link
	%% The data within this table is immutable once created
	submission_subject {
		BIGINT id PK "" 
		enum subject_type "CARBON_INVENTORY | REDUCTION_PROJECT | NEUTRALIZATION_PLAN | ORGANIZATION_DATA"
		timestamptz created_at  ""  
		BIGINT created_by FK ""  
	}

	%% The data within this table is immutable once created
	submission_subject_carbon_inventory {
		BIGINT subject_id PK "FK"
		BIGINT carbon_inventory_id FK "UNIQUE carbon_inventory(id)"
	}
	
	%% The data within this table is immutable once created
	submission_subject_reduction_project {
		BIGINT subject_id PK "FK"
		BIGINT reduction_project_id FK "UNIQUE reduction_project(id)"
	}
	
	%% The data within this table is immutable once created
	submission_subject_neutralization_plan {
		BIGINT subject_id PK "FK"
		BIGINT neutralization_plan_id FK "UNIQUE neutralization_plan(id)"
	}

	%% The data within this table is immutable once created
	submission_subject_organization_data {
		BIGINT subject_id PK "FK"
		BIGINT organization_data_id FK "UNIQUE organization_data(id)"
	}

	submission {
		BIGINT id PK "" 
		BIGINT subject_id FK "submission_subject(id)" 
		enum status "PENDING | APPROVED | REJECTED"
		BIGINT reviewer_id FK "NULLABLE, user(id)"
		text review_comments "NULLABLE"
		timestamptz created_at  ""  
		timestamptz updated_at  ""  
		BIGINT created_by FK "NULLABLE, user(id)"
		BIGINT updated_by FK "NULLABLE, user(id)"  
		%% UNIQUE INDEX on subject_id WHERE status IN ('PENDING', 'APPROVED')
	}

	recognition_catalog {
		BIGINT id PK ""
		string name "UNIQUE"
		enum recognition_type  "MEASUREMENT|VERIFICATION|REDUCTION|NEUTRALIZATION" 
	}

	recognition {
		BIGINT id PK ""  
		BIGINT organization_id FK ""  
		BIGINT recognition_catalog_id FK ""  
		BIGINT submission_id FK ""
		date awarded_at  ""  
		date valid_until  ""  
		timestamptz created_at  ""  
		timestamptz updated_at  ""  
		BIGINT created_by FK ""  
		BIGINT updated_by FK ""
	}

	%% ============================================================
	%% 🟪 Files & attachments (3)
	%% ============================================================

	%% Generic file metadata table. Ownership is resolved via link tables
	%% (badge, submission_file) following the same polymorphic pattern used by submission_subject.
	%% mime_type and size_bytes are read from Azure blob properties at confirm-upload time,
	%% not provided by the client.
	file {
		BIGINT id PK ""
		string uuid "UNIQUE"
		string original_name ""
		string mime_type "read from Azure blob properties"
		int size_bytes "read from Azure blob properties"
		string blob_path ""
		enum status "ACTIVE | DELETED"
		BIGINT created_by_id FK "user(id)"
		timestamptz created_at ""
		timestamptz deleted_at "NULLABLE"
	}

	%% Link table: file ↔ badge type
	%% Only one badge per type may have status ACTIVE at a time.
	%% Uploading a new badge automatically sets the previous one to INACTIVE.
	badge {
		BIGINT id PK ""
		enum type "CARBON_INVENTORY | ORGANIZATION_DATA"
		BIGINT file_id FK "file(id)"
		enum status "ACTIVE | INACTIVE"
		timestamptz created_at "DEFAULT now()"
	}

	%% Link table: file ↔ submission
	%% type distinguishes between document attachments and recognition certificates.
	submission_file {
		BIGINT file_id PK "FK file(id)"
		BIGINT submission_id FK "submission(id)"
		enum type "SUBMIT_ATTACHMENT | RECOGNITION | REVIEW_ATTACHMENT"
	}

