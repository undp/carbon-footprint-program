	%% ============================================================
	%% 🟩 Methodology & factors (10)
	%% ============================================================
	
	methodology_version {
		BIGINT id PK ""
		BIGINT country_id FK ""
		string name  ""
		string description  ""
		string regulation ""
		string version ""
		enum status "PUBLISHED | UNPUBLISHED | DELETED"
		timestamptz created_at  ""
		timestamptz updated_at  "NULLABLE"
		BIGINT created_by_id FK "NULLABLE"
		BIGINT updated_by_id FK "NULLABLE"
		%% Enforce via trigger at most 1 active per country
	}

	category {
		BIGINT id PK ""
		BIGINT methodology_version_id FK ""
		string name ""
		string icon ""
		%% just for displaying
		string synonyms ""
		%% just for displaying
		string description ""
		%% Position must be > 0 (enforced by DB CHECK constraint)
		int position ""
		enum status "ACTIVE | DELETED"
		timestamptz created_at  ""
		timestamptz updated_at  "NULLABLE"
		BIGINT created_by_id FK "NULLABLE"
		BIGINT updated_by_id FK "NULLABLE"
		%% UNIQUE(methodology_version_id, name)
		%% UNIQUE(methodology_version_id, position)
	}

	subcategory {
		BIGINT id PK ""
		BIGINT category_id FK ""    
		string name  ""  
		string icon ""
		%% just for displaying
		string description  ""
		enum status "ACTIVE | DELETED"
		timestamptz created_at  ""  
		timestamptz updated_at  ""  
		BIGINT created_by FK ""  
		BIGINT updated_by FK ""
	}

	emission_factor_dimension {
		BIGINT id PK ""   
		BIGINT subcategory_id FK "" 
		%% Like: FUEL_GROUP, FUEL_TYPE, GAS_TYPE
		text code "" 
		%% Like: Tipo de combustible, Tipo de gas
		text name ""
		%% Like: 1, 2, 3 (order in UI & logic)           
		int position ""
		boolean is_required ""
		timestamptz created_at  ""  
		timestamptz updated_at  ""  
		BIGINT created_by FK ""  
		BIGINT updated_by FK "" 
		%% UNIQUE(subcategory_id, position),
		%% UNIQUE(subcategory_id, code)
	}

	emission_factor_dimension_value {
		BIGINT id PK ""
		BIGINT dimension_id FK "emission_factor_dimension(id)"
		BIGINT parent_value_id FK "NULLABLE, emission_factor_dimension_value(id)"
		%% Like: Natural gas, Diesel, Kerosene, etc
		string value ""
		boolean is_active ""
		timestamptz created_at  ""
		timestamptz updated_at  ""
		BIGINT created_by FK "NULLABLE"
		BIGINT updated_by FK "NULLABLE"
		%% UNIQUE(dimension_id, value)
	}

	emission_factor {
		BIGINT id PK ""
		BIGINT subcategory_id FK ""
		%% Emission factors currently support up to two dimensions via fixed columns.
		%% A binding table was considered for unbounded dimensions but intentionally not used to keep queries and constraints simple.
		BIGINT dimension_value_1_id FK "NULLABLE, emission_factor_dimension_value(id)"
		BIGINT dimension_value_2_id FK "NULLABLE, emission_factor_dimension_value(id)"
		BIGINT rate_measurement_unit_id FK ""
		string source  ""
		JSONB gas_details ""
		numeric value  ""
		enum status "ACTIVE | DELETED"
		timestamptz created_at  ""
		timestamptz updated_at  ""
		BIGINT created_by FK ""
		BIGINT updated_by FK ""
		%% Enforce UNIQUE (subcategory_id, dimension_value_1_id, dimension_value_2_id) WHERE status = 'ACTIVE'
	}

	sector_profiling {
		BIGINT id PK ""  
		BIGINT country_sector_id FK ""  
		BIGINT subcategory_id FK ""  
		timestamptz created_at  ""  
		timestamptz updated_at  ""  
		BIGINT created_by FK ""  
		BIGINT updated_by FK ""  
