# =============================================================================
# Huella Latam — Keycloak PRODUCTION environment
# =============================================================================
# Consumed by compose/keycloak-db.yaml and compose/keycloak.prod.yaml. This is
# a SEPARATE env file from .env.prod.dockercompose (the api/web prod stack) —
# the two are combined only when you also run docker-compose.prod.yml in the
# same invocation (see "Combining with the api/web stack" below).
#
# Quick start (run from the REPO ROOT):
#   cp .env.prod.keycloak.example .env.prod.keycloak
#   chmod 600 .env.prod.keycloak   # it will hold real secrets
#   # fill in every empty / <placeholder> value below, then:
#   docker compose --project-directory . \
#     -f compose/keycloak-db.yaml -f compose/keycloak.prod.yaml \
#     --env-file .env.prod.keycloak up -d --build
#
# Like .env.prod.dockercompose, this template has NO working defaults for
# secrets — compose fails fast (at `up`/`config` time) if a required
# (`${VAR:?...}`) value is missing. `.env.prod.keycloak` is gitignored; this
# template is committed.
#
# ⚠️  ALWAYS pass `--project-directory .` (from the repo root) with these files,
#     so relative paths (build context, volume sources, ./infra/keycloak) resolve
#     to the repo root regardless of `-f` order. Full rationale at the top of
#     compose/keycloak.prod.yaml.
#
# ⚠️  Variable precedence: shell env  >  --env-file  >  in-file defaults.
#     Shell/direnv exports silently override this file — see
#     docs/operations/docker-compose.md → Troubleshooting for diagnosis.
# =============================================================================

# -----------------------------------------------------------------------------
# Combining with the bundled DB vs an external managed Postgres
# -----------------------------------------------------------------------------
# (a) Bundled DB (compose/keycloak-db.yaml) — simplest, single-host:
#       docker compose --project-directory . \
#         -f compose/keycloak-db.yaml -f compose/keycloak.prod.yaml \
#         --env-file .env.prod.keycloak up -d --build
#     Leave KC_DB_URL_HOST at its default (`keycloak-db`, the bundled
#     service's name) and fill KC_DB_USERNAME/KC_DB_PASSWORD/KC_DB_URL_DATABASE
#     below — both files read the SAME vars, so Postgres and Keycloak agree
#     automatically.
#
# (b) External managed Postgres (HA / managed backups) — do NOT include
#     compose/keycloak-db.yaml at all:
#       docker compose --project-directory . -f compose/keycloak.prod.yaml \
#         --env-file .env.prod.keycloak up -d --build
#     Set KC_DB_URL_HOST (and KC_DB_URL_PORT/KC_DB_URL_DATABASE if not the
#     defaults) to the external server, and KC_DB_USERNAME/KC_DB_PASSWORD to
#     credentials your DBA provisioned there — same vars, different values.
#     For anything the component vars can't express (e.g. `?sslmode=require`),
#     set the full KC_DB_URL instead; when non-empty it takes precedence over
#     the KC_DB_URL_HOST/PORT/DATABASE components.
#
# COMPOSE_FILE alternative to `-f -f` (works for either (a) or (b) — just
# include or omit the `compose/keycloak-db.yaml` segment; still pass
# `--project-directory .` on the CLI):
#   COMPOSE_FILE=compose/keycloak-db.yaml:compose/keycloak.prod.yaml
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Combining with the api/web prod stack (docker-compose.prod.yml) — needed so
# the API can reach Keycloak internally for JWKS. See the full explanation at
# the top of compose/keycloak.prod.yaml. Short version:
#   docker compose --project-directory . -f docker-compose.prod.yml \
#     -f compose/keycloak-db.yaml -f compose/keycloak.prod.yaml \
#     --env-file .env.prod.dockercompose --env-file .env.prod.keycloak \
#     up -d --build
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Database — shared by compose/keycloak-db.yaml (as POSTGRES_*) and
# compose/keycloak.prod.yaml (as KC_DB_*). See scenario (a)/(b) above.
# -----------------------------------------------------------------------------
# Vendor — Keycloak build-time option; changing it requires a rebuild
# (`docker compose ... build keycloak`). The repo standard is postgres.
KC_DB=postgres
# Full JDBC URL override — leave empty to build the URL from the component vars
# below (recommended). Set it only for extras the components can't express (e.g.
# ?sslmode=require), NOT for the schema — KC_DB_SCHEMA is the only supported way
# to set that. See docs/infrastructure/KeycloakSetup.md → "Overriding KC_DB_URL".
KC_DB_URL=
# Component vars. HOST and PORT are decided together by HOW Keycloak reaches
# the DB: scenario (a) bundled via the docker network → keycloak-db + 5432 (the
# container's internal port — the defaults below); scenario (b) external server
# → its DNS/IP + the port it listens on. NEVER localhost (inside the container
# that is Keycloak itself). See docs/infrastructure/KeycloakSetup.md →
# "External database — choosing KC_DB_URL_HOST".
KC_DB_URL_HOST=keycloak-db
KC_DB_URL_PORT=5432
KC_DB_URL_DATABASE=keycloak
# Postgres schema (namespace) for Keycloak's tables. Defaults to `public`; set
# it only in scenario (b) when Keycloak shares a managed Postgres with other
# tenants and must be namespaced. The schema must already EXIST — Keycloak
# creates its tables in it but not the schema; have your DBA provision it
# alongside the KC_DB_USERNAME grant (see the DBA contract in
# docs/operations/production-deployment.md).
KC_DB_SCHEMA=public
# ⚠️ REQUIRED, no default. In scenario (a) this ALSO becomes the bundled
# Postgres's own user (compose/keycloak-db.yaml creates it on first boot).
KC_DB_USERNAME=
KC_DB_PASSWORD=
# (Scenario (a) only: the bundled DB publishes a fixed 127.0.0.1:15432 on the
# host for inspection with psql — tunnel over SSH from elsewhere. Keycloak
# never uses that mapping; it connects over the docker network.)
# Co-location overrides (consumed by compose/keycloak-db.yaml) — set both only
# to run a dev AND a prod bundled DB on one host without name collisions.
# Defaults shown:
# KC_DB_CONTAINER_NAME=huella-latam-keycloak-db
# KC_DB_VOLUME_NAME=huella-latam-keycloak-db-data

# -----------------------------------------------------------------------------
# Hostname — the BROWSER-facing public URL Keycloak is reachable at. Becomes
# the token issuer (`iss`); must exactly match JWKS_ISSUER / VITE_OIDC_ISSUER
# in .env.prod.dockercompose (the issuer/JWKS-host split — see
# docs/infrastructure/KeycloakSetup.md).
# -----------------------------------------------------------------------------
# e.g. https://id.example.org
KC_HOSTNAME=
# Rejects requests for any other hostname. Leave `true` in production.
KC_HOSTNAME_STRICT=true

# -----------------------------------------------------------------------------
# Web app origin for the huella-web client (redirect URIs / web origins /
# post-logout). Scheme + host only, NO trailing slash — matches the origin of
# VITE_OIDC_REDIRECT_URI in .env.prod.dockercompose. First boot only:
# --import-realm skips an existing realm, so later changes go through the Admin
# Console — but keep it set, compose requires it non-empty on every `up`.
# -----------------------------------------------------------------------------
# e.g. https://app.example.org (no trailing slash)
HUELLA_WEB_ORIGIN=

# -----------------------------------------------------------------------------
# Reverse proxy vs direct TLS — pick ONE mode.
# -----------------------------------------------------------------------------
# Mode A (default/primary) — a reverse proxy in front of this container
# terminates TLS and forwards plain HTTP with X-Forwarded-* headers.
# KC_PROXY_HEADERS=xforwarded is the 26.x option name (NOT the old KC_PROXY).
KC_PROXY_HEADERS=xforwarded
# Comma-separated proxy IP(s)/CIDR Keycloak trusts to send X-Forwarded-* headers.
# Default 0.0.0.0/0,::/0 = trust all (only the reverse proxy should reach KC's HTTP
# port). Harden by setting this to the reverse proxy's own address.
KC_PROXY_TRUSTED_ADDRESSES=0.0.0.0/0,::/0
KC_HTTP_ENABLED=true

# Mode B — Keycloak terminates TLS itself (no reverse proxy in front of it).
# Set KC_HTTP_ENABLED=false above, and both vars below to PEM files placed
# under KC_TLS_CERT_DIR (mounted read-only into the container at
# /opt/keycloak/certs). Leave all three empty/default for Mode A.
# Note: in mode B the management interface (port 9000) inherits TLS too, so
# the compose healthcheck degrades to a TCP-connect probe (see the
# healthcheck note in compose/keycloak.prod.yaml).
KC_HTTPS_CERTIFICATE_FILE=
KC_HTTPS_CERTIFICATE_KEY_FILE=
# Host directory holding the PEM files above (only read if the two vars above
# are set) — e.g. KC_HTTPS_CERTIFICATE_FILE=/opt/keycloak/certs/tls.crt
# Relative paths resolve against the project directory (repo root) as long as
# you always pass `--project-directory .` per the note at the top of this file.
KC_TLS_CERT_DIR=./certs/keycloak

# -----------------------------------------------------------------------------
# Metrics — health is always on (needed by this stack's own healthcheck).
# Metrics is a Keycloak build-time option; changing it requires a rebuild.
# -----------------------------------------------------------------------------
KC_METRICS_ENABLED=false

# -----------------------------------------------------------------------------
# Bootstrap admin (Keycloak 26.x names — NOT KEYCLOAK_ADMIN/KEYCLOAK_ADMIN_PASSWORD).
# TEMPORARY: only used on the very first boot, when the `master` realm doesn't
# exist yet. Generate a strong password:
#   openssl rand -base64 24
# After first boot: log in, create a named permanent admin, then disable/delete
# this bootstrap account and ROTATE these two values to fresh throwaway ones.
# Do NOT blank them out: compose requires them non-empty (`${VAR:?}`) on every
# `up`, so an emptied file breaks the next deploy.
# -----------------------------------------------------------------------------
KC_BOOTSTRAP_ADMIN_USERNAME=
KC_BOOTSTRAP_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Published ports (host:container, with an optional ip: bind). Host side is
# 18080 not 8080 to avoid the api's host 8080 (1-prefix, like the DB's 15432);
# the container stays 8080 so the internal JWKS_URI (http://keycloak:8080/...)
# is unaffected. In mode A Keycloak trusts X-Forwarded-* headers, so ONLY the
# reverse proxy should reach the HTTP port — anything else hitting it directly
# can spoof client IP/scheme. Keep the loopback default when the proxy is on
# this host; widen to a firewalled proxy-only interface (e.g. <lan-ip>:18080)
# only for a remote proxy. KC_HTTPS_PORT (mode B only) likewise defaults to
# loopback; widen it to <iface>:8443 for a remote proxy/direct access. The
# management port (9000) is never published.
# -----------------------------------------------------------------------------
KC_HTTP_PORT=127.0.0.1:18080
KC_HTTPS_PORT=127.0.0.1:8443

# -----------------------------------------------------------------------------
# Resource limits (applied via mem_limit/cpus directly, and mirrored under
# deploy.resources.limits for Swarm compatibility — see the compose files).
# Defaults are a reasonable floor for a single-realm IdP; raise under load.
# -----------------------------------------------------------------------------
KC_MEM_LIMIT=1536m
KC_CPUS=2
KC_DB_MEM_LIMIT=512m
KC_DB_CPUS=1
