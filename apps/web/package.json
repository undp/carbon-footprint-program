{
  "name": "web",
  "version": "0.0.0",
  "description": "Web application for Huella Latam",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build-deps": "pnpm --filter @repo/database run build && pnpm --filter @repo/types run build && pnpm --filter @repo/utils run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "start": "vite preview",
    "clean": "rimraf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.27.0",
    "@azure/msal-react": "^3.0.23",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/roboto": "^5.2.9",
    "@fontsource/roboto": "^5.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@mui/x-charts": "^8.20.0",
    "@mui/x-data-grid": "^8.20.0",
    "@mui/x-date-pickers": "^8.19.0",
    "@repo/types": "workspace:*",
    "@repo/utils": "workspace:*",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-router": "^1.139.3",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.1.0",
    "ky": "^1.14.1",
    "lodash-es": "^4.17.22",
    "notistack": "^3.0.2",
    "pino": "catalog:shared",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.1",
    "tailwindcss": "^4.1.17",
    "xlsx": "^0.18.5",
    "zod": "catalog:shared",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@hookform/devtools": "^4.4.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tanstack/react-router-devtools": "^1.139.3",
    "@tanstack/router-plugin": "^1.139.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "catalog:shared",
