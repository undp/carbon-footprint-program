    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.15",
    "baseline-browser-mapping": "^2.9.15",
    "eslint": "catalog:shared",
    "jsdom": "^28.1.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:shared",
    "vite": "^7.2.4",
    "vitest": "catalog:shared"
  }
