{
  "extends": "@repo/typescript-config/web.json",
  "include": ["src"],
  "exclude": ["src/**/__tests__/**"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@components": ["./src/components"],
      "@components/*": ["./src/components/*"],
      "@screens": ["./src/screens"],
      "@screens/*": ["./src/screens/*"],
      "@assets": ["./src/assets"],
      "@assets/*": ["./src/assets/*"],
      "@icons": ["./src/icons"],
      "@icons/*": ["./src/icons/*"],
      "@interfaces": ["./src/interfaces"],
      "@interfaces/*": ["./src/interfaces/*"]
    },
    "moduleResolution": "bundler"
  }
}
