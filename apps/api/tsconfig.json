{
  "extends": "@repo/typescript-config/api.json",
  "include": ["src"],
  "exclude": [
    "src/test/**",
    "**/*.example.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "node_modules"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
