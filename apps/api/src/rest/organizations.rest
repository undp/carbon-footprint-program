@baseUrl = http://localhost:8080
@organizationId = 1

### Get My Organizations
GET {{baseUrl}}/api/app/organizations/me HTTP/1.1


### Get Organization by ID
GET {{baseUrl}}/api/app/organizations/{{organizationId}} HTTP/1.1


### Create Organization
POST {{baseUrl}}/api/app/organizations HTTP/1.1
Content-Type: application/json

{
  "legalName": "Acme Corporation S.A.",
  "tradeName": "Acme Corp",
  "taxId": "12345678-9",
  "countryOrganizationSizeId": "1",
  "sectorId": "1",
  "subsectorId": "1",
  "employeesCount": 150,
  "address": "123 Main Street, Capital City, Country",
  "representativeFullName": "John Doe",
  "representativeTaxId": "98765432-1",
  "representativePositionId": "1",
  "representativePhone": "+1234567890",
  "representativeEmail": "john.doe@example.com",
  "mainActivityId": "1"
}


