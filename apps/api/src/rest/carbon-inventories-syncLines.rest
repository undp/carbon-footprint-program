Content-Type: application/json

{
  "create": [
    {
      "subcategoryId": "1",
      "dimensionValue1Id": null,
      "dimensionValue2Id": null,
      "measurementUnitId": null,
      "quantity": null,
      "factorSource": null,
      "baseFactorId": null,
      "appliedFactorValue": null,
      "appliedFactorRateMeasurementUnitId": null,
      "manualTotalEmissions": null,
      "comment": "New line created in batch"
    }
  ],
  "update": [
    {
      "id": "3",
      "dimensionValue1Id": "1",
      "dimensionValue2Id": null,
      "measurementUnitId": "1",
      "quantity": 150,
      "factorSource": "Metodología GEI",
      "baseFactorId": "1",
      "appliedFactorValue": 2.0,
      "appliedFactorRateMeasurementUnitId": "1",
      "manualTotalEmissions": null,
      "comment": "Existing line updated in batch"
    }
  ],
  "delete": [
    { "id": "4" }
  ]
}


