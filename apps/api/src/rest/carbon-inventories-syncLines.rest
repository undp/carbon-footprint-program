### Error Case - Line belongs to different inventory
# First create a line in inventory 2, then try to update it via inventory 1
POST {{baseUrl}}/api/carbon-inventories/1/lines/sync HTTP/1.1
Content-Type: application/json

{
  "create": [],
  "update": [
    {
      "id": "100",
      "dimensionValue1Id": null,
      "dimensionValue2Id": null,
      "measurementUnitId": null,
      "quantity": null,
      "factorSource": null,
      "baseFactorId": null,
      "appliedFactorValue": null,
      "appliedFactorRateMeasurementUnitId": null,
      "manualTotalEmissions": null,
      "comment": "This should fail - line from different inventory"
    }
  ],
  "delete": []
}


