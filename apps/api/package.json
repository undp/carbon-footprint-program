{
  "name": "api",
  "version": "0.0.0",
  "description": "API server for Huella Latam",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:base": "STORAGE_PROVIDER=azure_blob_storage vitest run --config vitest.base.config.ts",
    "test:storage-azure": "STORAGE_PROVIDER=azure_blob_storage vitest run --config vitest.storage.config.ts",
    "test:storage-minio": "STORAGE_PROVIDER=minio vitest run --config vitest.storage.config.ts",
    "test:coverage": "COVERAGE_DIR=coverage-artifacts/base pnpm run test:base && COVERAGE_DIR=coverage-artifacts/storage-azure pnpm run test:storage-azure && COVERAGE_DIR=coverage-artifacts/storage-minio pnpm run test:storage-minio && node ../../scripts/check-coverage.mjs coverage-artifacts",
    "test:verify-storage-manifest": "tsx test/setup/assertStorageTestManifest.ts",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist .turbo tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@fastify/autoload": "^6.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/error": "^4.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/under-pressure": "^9.0.3",
    "@repo/constants": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/storage": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/utils": "workspace:*",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^7.0.0",
    "jwks-rsa": "^4.1.0",
    "lodash-es": "^4.18.1",
    "openai": "^6.35.0",
    "pino": "catalog:shared",
    "zod": "catalog:shared"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/seed": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testcontainers/azurite": "^12.0.4",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "catalog:shared",
    "@vitest/coverage-v8": "catalog:shared",
    "@vitest/ui": "catalog:shared",
    "eslint": "catalog:shared",
    "pino-pretty": "^13.1.3",
    "rimraf": "catalog:shared",
    "testcontainers": "^12.0.4",
    "tsc-alias": "1.8.17",
    "tsx": "catalog:shared",
    "typescript": "catalog:shared",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:shared"
  }
}
