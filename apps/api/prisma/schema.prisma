generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model user {
    id        Int      @id @default(autoincrement())
    email     String   @unique
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model book {
    id        Int      @id @default(autoincrement())
    title     String   @unique
    author    String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
