{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "API_HOST",
    "API_PORT",
    "NODE_ENV",
    "DATABASE_URL",
    "JWT_SECRET",
    "LOG_LEVEL",
    "AZURE_EXTERNAL_TENANT_ID",
    "AZURE_API_CLIENT_ID",
    "AZURE_EXTERNAL_TENANT_SUBDOMAIN",
    "AUTH_PROVIDER",
    "FORCED_USER_EMAIL_WHEN_NO_PROVIDER",
    "FORCED_USER_IDP_ID_WHEN_NO_PROVIDER",
    "JWKS_URI",
    "JWKS_ISSUER",
    "JWKS_AUDIENCE",
    "DEV",
    "IS_DEMO_APP",
    "APP_VERSION",
    "CI",
    "AZURE_STORAGE_ACCOUNT_NAME",
    "AZURE_STORAGE_CONTAINER_NAME"
  ],
  "tasks": {
    "clean": {
      "cache": false,
      "dependsOn": ["^clean"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**", "*.tsbuildinfo", ".turbo/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^clean", "^build"],
      "inputs": ["$TURBO_DEFAULT$", "*.ts"],
      "outputs": []
    },
    "build": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build", "build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": []
    },
    "test": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "*tests/**"],
      "outputs": []
    },
    "lint": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "*.ts"],
      "outputs": []
    },
    "type-check": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json"],
      "outputs": []
    },
    "@repo/database#lint": {
      "cache": false,
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$", "*.ts"],
      "outputs": []
    }
  }
}
