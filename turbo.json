{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "API_HOST",
    "API_PORT",
    "MAX_EVENT_LOOP_DELAY_MS",
    "MAX_EVENT_LOOP_UTILIZATION",
    "NODE_ENV",
    "DATABASE_URL",
    "JWT_SECRET",
    "LOG_LEVEL",
    "AUTH_PROVIDER",
    "FORCED_USER_EMAIL",
    "FORCED_USER_IDP_ID",
    "JWKS_URI",
    "JWKS_ISSUER",
    "JWKS_AUDIENCE",
    "JWKS_REQUIRED_SCOPE",
    "JWKS_SKIP_SCOPE_CHECK",
    "DEV",
    "APP_VERSION",
    "CI",
    "AZURE_STORAGE_ACCOUNT_NAME",
    "AZURE_STORAGE_CONTAINER_NAME",
    "AZURE_STORAGE_TENANT_ID",
    "AZURE_STORAGE_CLIENT_ID",
    "AZURE_STORAGE_CLIENT_SECRET",
    "STORAGE_PROVIDER",
    "MINIO_ENDPOINT",
    "MINIO_ACCESS_KEY",
    "MINIO_SECRET_KEY",
    "MINIO_BUCKET",
    "MINIO_REGION",
    "MINIO_FORCE_PATH_STYLE",
    "MINIO_RELAY_ENABLED",
    "API_ORIGIN",
    "ALLOWED_ORIGIN",
    "VITE_API_BASE_URL",
    "SUPERADMIN_EMAIL",
    "LOCAL_BYPASS_REQUIRED_FIELDS",
    "CHATBOT_ENABLED",
    "LLM_PROVIDER",
    "COOKIE_SECRET",
    "AZURE_OPENAI_ENDPOINT",
    "AZURE_OPENAI_DEPLOYMENT_NAME"
  ],
  "tasks": {
    "clean": {
      "cache": false,
      "dependsOn": ["^clean"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**", "tsconfig.build.tsbuildinfo", ".turbo/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "*.ts"],
      "outputs": []
    },
    "build": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build", "build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": []
    },
    "test": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "*tests/**"],
      "outputs": []
    },
    "test:coverage": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "*tests/**"],
      "outputs": []
    },
    "test:leg": {
      "cache": false,
      "dependsOn": ["^build"],
      "passThroughEnv": ["LEG"],
      "inputs": ["$TURBO_DEFAULT$", "*tests/**"],
      "outputs": []
    },
    "test:coverage:merge": {
      "cache": false,
      // No `^build`: `vitest run --merge-reports --coverage` runs no tests — it
      // reads the blob JSON and maps coverage onto apps/api/src/** from the
      // checkout. It never loads globalSetup/setupFiles and imports no @repo/*
      // module, so building the workspace deps here is wasted CI time.
      "dependsOn": [],
      "inputs": ["$TURBO_DEFAULT$", "*tests/**"],
      "outputs": []
    },
    "test:verify-storage-manifest": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "lint": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "*.ts"],
      "outputs": []
    },
    "type-check": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json"],
      "outputs": []
    },
    "db:restore": {
      "cache": false,
      "dependsOn": ["build"]
    },
    "seed": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "@repo/database#lint": {
      "cache": false,
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$", "*.ts"],
      "outputs": []
    },
    "@repo/database#type-check": {
      "cache": false,
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json"],
      "outputs": []
    }
  }
}
