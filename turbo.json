{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "API_HOST",
    "API_PORT",
    "NODE_ENV",
    "DATABASE_URL",
    "JWT_SECRET",
    "LOG_LEVEL",
    "AUTH_PROVIDER",
    "FORCED_USER_EMAIL",
    "FORCED_USER_IDP_ID",
    "JWKS_URI",
    "JWKS_ISSUER",
    "JWKS_AUDIENCE",
    "JWKS_REQUIRED_SCOPE",
    "JWKS_SKIP_SCOPE_CHECK",
    "DEV",
    "APP_VERSION",
    "CI",
    "AZURE_STORAGE_ACCOUNT_NAME",
    "AZURE_STORAGE_CONTAINER_NAME",
    "AZURE_STORAGE_TENANT_ID",
    "AZURE_STORAGE_CLIENT_ID",
    "AZURE_STORAGE_CLIENT_SECRET",
    "STORAGE_PROVIDER",
    "MINIO_ENDPOINT",
    "MINIO_ACCESS_KEY",
    "MINIO_SECRET_KEY",
    "MINIO_BUCKET",
    "MINIO_REGION",
    "MINIO_FORCE_PATH_STYLE",
    "ALLOWED_ORIGIN",
    "SUPERADMIN_EMAIL",
    "LOCAL_BYPASS_REQUIRED_FIELDS"
  ],
  "tasks": {
    "clean": {
      "cache": false,
      "dependsOn": ["^clean"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**", "tsconfig.build.tsbuildinfo", ".turbo/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^clean", "^build"],
      "inputs": ["$TURBO_DEFAULT$", "*.ts"],
      "outputs": []
    },
    "build": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build", "build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": []
    },
    "test": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "*tests/**"],
      "outputs": []
    },
    "lint": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "*.ts"],
      "outputs": []
    },
    "type-check": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json"],
      "outputs": []
    },
    "db:restore": {
      "cache": false,
      "dependsOn": ["build"]
    },
    "seed": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "@repo/database#lint": {
      "cache": false,
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$", "*.ts"],
      "outputs": []
    }
  }
}
