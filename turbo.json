{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "API_HOST",
    "API_PORT",
    "NODE_ENV",
    "DATABASE_URL",
    "JWT_SECRET",
    "LOG_LEVEL",
    "AZURE_EXTERNAL_TENANT_ID",
    "AZURE_API_CLIENT_ID",
    "AUTH_PROVIDER"
  ],
  "tasks": {
    "clean": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", "*.ts"],
      "outputs": []
    },
    "build": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": []
    },
    "test": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", "*tests/**"],
      "outputs": []
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "*.ts"],
      "outputs": []
    },
    "type-check": {
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json"],
      "outputs": []
    }
  }
}
