# =============================================================================
# Huella Latam — PRODUCTION scenario (on-premise, external PostgreSQL)
# =============================================================================
# Quick start (from a repo checkout at the release tag):
#   cp deploy/prod-external-db/.env.example .env.prod.dockercompose
#   chmod 600 .env.prod.dockercompose      # it will hold real secrets
#   # fill in every empty / <placeholder> value below, then:
#   docker compose --env-file .env.prod.dockercompose up -d --build
#
# Unlike the dev template, this file has NO working defaults — every
# placeholder must be filled for the deployment. The scenario (which compose
# files are stacked) is selected by COMPOSE_FILE below — see deploy/README.md.
# `.env.prod.dockercompose` is gitignored (so it can coexist with a dev
# `.env.dockercompose` on a builder machine); this template is committed.
#
# Full guide: docs/operations/production-deployment.md
#
# ⚠️  Variable precedence: docker-compose interpolation uses
#     shell env  >  --env-file  >  defaults
#     If your shell (e.g. direnv / .envrc) exports any of these vars, those
#     exports SILENTLY OVERRIDE this file. See
#     `docs/operations/docker-compose.md` → Troubleshooting → "Compose uses the
#     wrong value for a variable" for diagnosis and fixes.
# =============================================================================

# -----------------------------------------------------------------------------
# Scenario (consumed by docker compose itself, not by the apps)
# Base + external-database overlay: only `api` and `web` run in Docker;
# PostgreSQL is an external server. COMPOSE_PROJECT_NAME namespaces
# containers/networks so this stack never collides with another one (e.g. a
# dev stack) on the same host.
# -----------------------------------------------------------------------------
COMPOSE_FILE=compose.yaml:compose/db.external.yaml
COMPOSE_PROJECT_NAME=huella-latam-prod
# Tag for the built/loaded images (huella-latam-api:prod, huella-latam-web:prod)
IMAGE_TAG=prod

# -----------------------------------------------------------------------------
# Database (EXTERNAL PostgreSQL — not part of this compose stack)
# -----------------------------------------------------------------------------
# Full connection string to the external PostgreSQL server (version >= 15;
# project standard is 18). Use the restricted APPLICATION user created by your
# DBA, NOT the superuser. Migrations and seeds are applied separately — see the
# deployment guide.
# ⚠️  The password MUST be URL-encoded if it contains special characters
#     (@ : / ? # & % $ ...). Encode it with:
#     node -e "console.log(encodeURIComponent(process.argv[1]))" 'p@ss#word'
DATABASE_URL=postgresql://<app-user>:<url-encoded-password>@<db-host>:5432/<db-name>?schema=public

# -----------------------------------------------------------------------------
# API (core)
# -----------------------------------------------------------------------------
# Host port to reach the API (container always listens on 8080)
API_PORT=8080
LOG_LEVEL=info
# Deployed version identifier — use the git tag being deployed
APP_VERSION=
# CORS: must match the web app's browser origin EXACTLY (scheme + host + port,
# no trailing slash). Same value as VITE_FRONT_BASE_URL below.
ALLOWED_ORIGIN=http://<server-host-or-dns>
# OPTIONAL — unused when AUTH_PROVIDER=jwks/easy-auth is fully configured
# (tokens are verified against the IdP's public keys, not this secret). It is
# only the static HMAC fallback if the JWKS config is incomplete; setting a
# strong value keeps that fallback unforgeable. Generate with:
# openssl rand -base64 48
JWT_SECRET=

# -----------------------------------------------------------------------------
# Authentication
# AUTH_PROVIDER: jwks | easy-auth   (production options)
#   jwks      → validates Azure Entra ID tokens (set the Azure block below)
#   easy-auth → Azure App Service Easy Auth headers (Azure-hosted compute only)
# -----------------------------------------------------------------------------
AUTH_PROVIDER=jwks

# Email promoted to superadmin by the promote-superadmin script (optional)
SUPERADMIN_EMAIL=

# Azure Entra ID — required when AUTH_PROVIDER=jwks
# AZURE_TENANT_TYPE: external (CIAM / ciamlogin.com) | organizational (Azure AD)
# ⚠️  With AZURE_TENANT_TYPE=external and AZURE_TENANT_ID set, the API refuses
#     to boot unless AZURE_TENANT_SUBDOMAIN (or JWKS_URI) is also set.
AZURE_TENANT_TYPE=external
AZURE_TENANT_ID=
AZURE_TENANT_SUBDOMAIN=
AZURE_API_CLIENT_ID=

# Generic JWKS overrides (optional, non-Azure IdPs)
JWKS_URI=
JWKS_ISSUER=
JWKS_AUDIENCE=
JWKS_REQUIRED_SCOPE=
JWKS_SKIP_SCOPE_CHECK=

# -----------------------------------------------------------------------------
# Azure Blob Storage
# On-premise hosts have NO Azure Managed Identity, so the dedicated storage
# Service Principal is required: when storage is enabled, set ALL THREE SP vars
# together (production-grade, vault-managed values). SP creation walkthrough:
# docs/operations/docker-compose.md → "Azure Blob Storage".
# Leaving AZURE_STORAGE_ACCOUNT_NAME empty disables file upload/download AND
# the badge/terms seeds — see the seed warning in the deployment guide.
# -----------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=files
# Dedicated SP for storage (Directory tenant where the storage account lives —
# intentionally separate from AZURE_TENANT_ID above, which is the auth tenant).
AZURE_STORAGE_TENANT_ID=
AZURE_STORAGE_CLIENT_ID=
AZURE_STORAGE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Web (Vite) — inlined into the bundle at BUILD time (docker build args).
# Changing any of these requires rebuilding the web image.
# -----------------------------------------------------------------------------
# Host port to reach the web app
WEB_PORT=80
# Browser-reachable API URL — uses the host-exposed API_PORT above, NOT the
# container-internal port.
VITE_API_BASE_URL=http://<server-host-or-dns>:8080
# Browser-reachable web URL — must match ALLOWED_ORIGIN above.
VITE_FRONT_BASE_URL=http://<server-host-or-dns>
VITE_APP_VERSION=
VITE_IS_DEMO_APP=false
# Azure MSAL config — mirror the API's Azure App Registration values.
VITE_AZURE_FRONT_CLIENT_ID=
VITE_AZURE_API_CLIENT_ID=
# Authority URL — derived from tenant type/id/subdomain:
#   organizational  → https://login.microsoftonline.com/<tenant-id>/v2.0
#   external (CIAM) → https://<subdomain>.ciamlogin.com/<tenant-id>/v2.0
VITE_AZURE_AUTH_AUTHORITY=https://<subdomain>.ciamlogin.com/<tenant-id>/v2.0
