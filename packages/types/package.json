{
  "name": "@repo/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build-deps": "pnpm --filter @repo/database run build",
    "predev": "pnpm build-deps",
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "type-check": "tsc --noEmit --project tsconfig.build.json",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@repo/database": "workspace:*",
    "zod": "catalog:shared"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:shared",
    "eslint": "catalog:shared",
    "typescript": "catalog:shared"
  }
}
