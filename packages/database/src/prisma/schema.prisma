generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model Country {
  id                       BigInt                    @id @default(autoincrement())
  name                     String
  isoCode                  String                    @unique @map("iso_code")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @default(now()) @updatedAt @map("updated_at")
  countryJobPositions      CountryJobPosition[]
  countryOrganizationSizes CountryOrganizationSize[]
  countrySectors           CountrySector[]
  countryParameters        CountryParameter[]
  methodologyVersions      MethodologyVersion[]

  @@map("country")
}

model CountryParameter {
  id          BigInt   @id @default(autoincrement())
  countryId   BigInt   @map("country_id")
  key         String
  value       String
  description String
  type        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  createdById BigInt?  @map("created_by_id")
  updatedById BigInt?  @map("updated_by_id")
  country     Country  @relation(fields: [countryId], references: [id])
  creator     User?    @relation("country_parameter_created_by", fields: [createdById], references: [id])
  updater     User?    @relation("country_parameter_updated_by", fields: [updatedById], references: [id])

  @@unique([countryId, key])
  @@map("country_parameter")
}

model SystemParameter {
  id          BigInt   @id @default(autoincrement())
  key         String   @unique
  value       String
  description String
  type        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  createdById BigInt?  @map("created_by_id")
  updatedById BigInt?  @map("updated_by_id")
  creator     User?    @relation("system_parameter_created_by", fields: [createdById], references: [id])
  updater     User?    @relation("system_parameter_updated_by", fields: [updatedById], references: [id])

  @@map("system_parameter")
}

model CountryOrganizationSize {
  id        BigInt   @id @default(autoincrement())
  countryId BigInt   @map("country_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  country   Country  @relation(fields: [countryId], references: [id])

  @@unique([countryId, name])
  @@map("country_organization_size")
}

model CountrySector {
  id                         BigInt                     @id @default(autoincrement())
  countryId                  BigInt                     @map("country_id")
  name                       String
  createdAt                  DateTime                   @default(now()) @map("created_at")
  updatedAt                  DateTime                   @default(now()) @updatedAt @map("updated_at")
  createdById                BigInt?                    @map("created_by_id")
  updatedById                BigInt?                    @map("updated_by_id")
  country                    Country                    @relation(fields: [countryId], references: [id])
  creator                    User?                      @relation("country_sector_created_by", fields: [createdById], references: [id])
  updater                    User?                      @relation("country_sector_updated_by", fields: [updatedById], references: [id])
  subsectors                 CountrySubsector[]
  organizationMainActivities OrganizationMainActivity[]

  @@unique([countryId, name])
  @@map("country_sector")
}

model CountrySubsector {
  id                         BigInt                     @id @default(autoincrement())
  countrySectorId            BigInt                     @map("country_sector_id")
  name                       String
  createdAt                  DateTime                   @default(now()) @map("created_at")
  updatedAt                  DateTime                   @default(now()) @updatedAt @map("updated_at")
  createdById                BigInt?                    @map("created_by_id")
  updatedById                BigInt?                    @map("updated_by_id")
  countrySector              CountrySector              @relation(fields: [countrySectorId], references: [id])
  creator                    User?                      @relation("country_subsector_created_by", fields: [createdById], references: [id])
  updater                    User?                      @relation("country_subsector_updated_by", fields: [updatedById], references: [id])
  organizationMainActivities OrganizationMainActivity[]

  @@unique([countrySectorId, name])
  @@map("country_subsector")
}

model OrganizationMainActivity {
  id                 BigInt            @id @default(autoincrement())
  name               String
  countrySectorId    BigInt?           @map("country_sector_id")
  countrySubsectorId BigInt?           @map("country_subsector_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @default(now()) @updatedAt @map("updated_at")
  createdById        BigInt?           @map("created_by_id")
  updatedById        BigInt?           @map("updated_by_id")
  countrySector      CountrySector?    @relation(fields: [countrySectorId], references: [id])
  countrySubsector   CountrySubsector? @relation(fields: [countrySubsectorId], references: [id])
  creator            User?             @relation("organization_main_activity_created_by", fields: [createdById], references: [id])
  updater            User?             @relation("organization_main_activity_updated_by", fields: [updatedById], references: [id])

  @@unique([name, countrySectorId, countrySubsectorId], map: "organization_main_activity_name_country_sector_id_country_s_key")
  @@map("organization_main_activity")
}

model CountryJobPosition {
  id        BigInt   @id @default(autoincrement())
  countryId BigInt   @map("country_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  country   Country  @relation(fields: [countryId], references: [id])
  users     User[]

  @@unique([countryId, name])
  @@map("country_job_position")
}

model Role {
  id               BigInt            @id @default(autoincrement())
  name             String            @unique
  description      String
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")
  organizationRole OrganizationRole?
  systemRole       SystemRole?

  @@map("role")
}

model OrganizationRole {
  id   BigInt @id
  role Role   @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("organization_role")
}

model SystemRole {
  id   BigInt @id
  role Role   @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("system_role")
}

model User {
  id                                   BigInt                         @id @default(autoincrement())
  uuid                                 String                         @unique @default(uuid()) @db.Uuid
  email                                String                         @unique
  countryJobPositionId                 BigInt                         @map("country_job_position_id")
  firstName                            String?                        @map("first_name")
  lastName                             String?                        @map("last_name")
  createdAt                            DateTime                       @default(now()) @map("created_at")
  updatedAt                            DateTime                       @default(now()) @updatedAt @map("updated_at")
  createdById                          BigInt?                        @map("created_by_id")
  updatedById                          BigInt?                        @map("updated_by_id")
  countryParametersCreated             CountryParameter[]             @relation("country_parameter_created_by")
  countryParametersUpdated             CountryParameter[]             @relation("country_parameter_updated_by")
  countrySectorsCreated                CountrySector[]                @relation("country_sector_created_by")
  countrySectorsUpdated                CountrySector[]                @relation("country_sector_updated_by")
  countrySubsectorsCreated             CountrySubsector[]             @relation("country_subsector_created_by")
  countrySubsectorsUpdated             CountrySubsector[]             @relation("country_subsector_updated_by")
  organizationMainActivitiesCreated    OrganizationMainActivity[]     @relation("organization_main_activity_created_by")
  organizationMainActivitiesUpdated    OrganizationMainActivity[]     @relation("organization_main_activity_updated_by")
  systemParametersCreated              SystemParameter[]              @relation("system_parameter_created_by")
  systemParametersUpdated              SystemParameter[]              @relation("system_parameter_updated_by")
  carbonInventoriesCreated             CarbonInventory[]              @relation("carbon_inventory_created_by")
  carbonInventoriesUpdated             CarbonInventory[]              @relation("carbon_inventory_updated_by")
  methodologyVersionsCreated           MethodologyVersion[]           @relation("methodology_version_created_by")
  methodologyVersionsUpdated           MethodologyVersion[]           @relation("methodology_version_updated_by")
  categoriesCreated                    Category[]                     @relation("category_created_by")
  categoriesUpdated                    Category[]                     @relation("category_updated_by")
  subcategoriesCreated                 Subcategory[]                  @relation("subcategory_created_by")
  subcategoriesUpdated                 Subcategory[]                  @relation("subcategory_updated_by")
  emissionFactorDimensionsCreated      EmissionFactorDimension[]      @relation("emission_factor_dimension_created_by")
  emissionFactorDimensionsUpdated      EmissionFactorDimension[]      @relation("emission_factor_dimension_updated_by")
  emissionFactorDimensionValuesCreated EmissionFactorDimensionValue[] @relation("emission_factor_dimension_value_created_by")
  emissionFactorDimensionValuesUpdated EmissionFactorDimensionValue[] @relation("emission_factor_dimension_value_updated_by")
  emissionFactorsCreated               EmissionFactor[]               @relation("emission_factor_created_by")
  emissionFactorsUpdated               EmissionFactor[]               @relation("emission_factor_updated_by")
  carbonInventoryLinesCreated          CarbonInventoryLine[]          @relation("carbon_inventory_line_created_by")
  carbonInventoryLinesUpdated          CarbonInventoryLine[]          @relation("carbon_inventory_line_updated_by")
  carbonInventoryLineInputsCreated     CarbonInventoryLineInput[]     @relation("carbon_inventory_line_input_created_by")
  carbonInventoryLineInputsUpdated     CarbonInventoryLineInput[]     @relation("carbon_inventory_line_input_updated_by")
  carbonInventoryLineFactorsCreated    CarbonInventoryLineFactor[]    @relation("carbon_inventory_line_factor_created_by")
  carbonInventoryLineFactorsUpdated    CarbonInventoryLineFactor[]    @relation("carbon_inventory_line_factor_updated_by")
  carbonInventoryLineResultsCreated    CarbonInventoryLineResult[]    @relation("carbon_inventory_line_result_created_by")
  carbonInventoryLineResultsUpdated    CarbonInventoryLineResult[]    @relation("carbon_inventory_line_result_updated_by")
  countryJobPosition                   CountryJobPosition             @relation(fields: [countryJobPositionId], references: [id])
  creator                              User?                          @relation("user_created_by", fields: [createdById], references: [id])
  usersCreated                         User[]                         @relation("user_created_by")
  updater                              User?                          @relation("user_updated_by", fields: [updatedById], references: [id])
  usersUpdated                         User[]                         @relation("user_updated_by")

  @@map("user")
}

model MeasurementUnit {
  id                     BigInt                     @id @default(autoincrement())
  name                   String
  magnitude              Magnitude
  abbreviation           String                     @unique
  baseFactor             Float                      @map("base_factor")
  isBase                 Boolean                    @map("is_base")
  rateUnitsAsDenominator RateMeasurementUnit[]      @relation("denominator_measurement_unit")
  rateUnitsAsNumerator   RateMeasurementUnit[]      @relation("numerator_measurement_unit")
  lineInputs             CarbonInventoryLineInput[]

  @@map("measurement_unit")
}

model RateMeasurementUnit {
  id                           BigInt                      @id @default(autoincrement())
  name                         String
  abbreviation                 String                      @unique
  numeratorMeasurementUnitId   BigInt                      @map("numerator_measurement_unit_id")
  denominatorMeasurementUnitId BigInt                      @map("denominator_measurement_unit_id")
  denominatorMeasurementUnit   MeasurementUnit             @relation("denominator_measurement_unit", fields: [denominatorMeasurementUnitId], references: [id])
  numeratorMeasurementUnit     MeasurementUnit             @relation("numerator_measurement_unit", fields: [numeratorMeasurementUnitId], references: [id])
  emissionFactors              EmissionFactor[]
  lineInputsAsManualFactor     CarbonInventoryLineInput[]  @relation("manual_factor_rate_unit")
  lineFactorsAsApplied         CarbonInventoryLineFactor[] @relation("applied_factor_rate_unit")

  @@map("rate_measurement_unit")
}

enum Magnitude {
  MASS
  VOLUME
  DISTANCE
  TIME

  @@map("Magnitude")
}

enum InventoryStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  DELETED

  @@map("inventory_status")
}

enum UsageMode {
  SIMPLIFIED
  EXPERT

  @@map("usage_mode")
}

/// UsageMode represents inventory-level behavior (SIMPLIFIED/EXPERT), while InputType represents per-line input method and introduces DIRECT for line-only direct input.
enum InputType {
  SIMPLIFIED
  EXPERT
  DIRECT

  @@map("input_type")
}

model StatusCatalog {
  id                  BigInt                @id @default(autoincrement())
  scope               String
  code                String
  name                String
  isTerminal          Boolean?              @map("is_terminal")
  isVisible           Boolean?              @map("is_visible")
  sortOrder           Int?                  @map("sort_order")
  isActive            Boolean?              @map("is_active")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at")
  methodologyVersions MethodologyVersion[]
  emissionFactors     EmissionFactor[]
  inventoryLines      CarbonInventoryLine[]

  @@unique([scope, code])
  @@map("status_catalog")
}

model MethodologyVersion {
  id                BigInt            @id @default(autoincrement())
  countryId         BigInt            @map("country_id")
  name              String
  description       String?
  statusId          BigInt            @map("status_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @default(now()) @updatedAt @map("updated_at")
  createdById       BigInt?           @map("created_by_id")
  updatedById       BigInt?           @map("updated_by_id")
  country           Country           @relation(fields: [countryId], references: [id])
  status            StatusCatalog     @relation(fields: [statusId], references: [id])
  creator           User?             @relation("methodology_version_created_by", fields: [createdById], references: [id])
  updater           User?             @relation("methodology_version_updated_by", fields: [updatedById], references: [id])
  categories        Category[]
  carbonInventories CarbonInventory[]

  // TODO: Enforce via trigger at most 1 active per country
  // TODO: Enforce somehow country's active_methodology_version_id must point to ACTIVE

  @@unique([countryId, name])
  @@map("methodology_version")
}

model Category {
  id                   BigInt             @id @default(autoincrement())
  methodologyVersionId BigInt             @map("methodology_version_id")
  name                 String
  synonyms             String?
  description          String?
  examples             String?
  // Position must be > 0 (enforced by DB CHECK constraint: category_position_check)
  position             Int
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @default(now()) @updatedAt @map("updated_at")
  createdById          BigInt?            @map("created_by_id")
  updatedById          BigInt?            @map("updated_by_id")
  methodologyVersion   MethodologyVersion @relation(fields: [methodologyVersionId], references: [id])
  creator              User?              @relation("category_created_by", fields: [createdById], references: [id])
  updater              User?              @relation("category_updated_by", fields: [updatedById], references: [id])
  subcategories        Subcategory[]

  @@unique([methodologyVersionId, name])
  @@unique([methodologyVersionId, position])
  @@map("category")
}

model Subcategory {
  id              BigInt                    @id @default(autoincrement())
  categoryId      BigInt                    @map("category_id")
  name            String
  description     String?
  examples        String?
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @default(now()) @updatedAt @map("updated_at")
  createdById     BigInt?                   @map("created_by_id")
  updatedById     BigInt?                   @map("updated_by_id")
  category        Category                  @relation(fields: [categoryId], references: [id])
  creator         User?                     @relation("subcategory_created_by", fields: [createdById], references: [id])
  updater         User?                     @relation("subcategory_updated_by", fields: [updatedById], references: [id])
  dimensions      EmissionFactorDimension[]
  emissionFactors EmissionFactor[]
  inventoryLines  CarbonInventoryLine[]

  @@unique([categoryId, name])
  @@map("subcategory")
}

model EmissionFactorDimension {
  id            BigInt                         @id @default(autoincrement())
  subcategoryId BigInt                         @map("subcategory_id")
  code          String
  name          String
  // Position must be > 0 (enforced by DB CHECK constraint: emission_factor_dimension_position_check)
  position      Int
  isRequired    Boolean                        @map("is_required")
  createdAt     DateTime                       @default(now()) @map("created_at")
  updatedAt     DateTime                       @default(now()) @updatedAt @map("updated_at")
  createdById   BigInt?                        @map("created_by_id")
  updatedById   BigInt?                        @map("updated_by_id")
  subcategory   Subcategory                    @relation(fields: [subcategoryId], references: [id])
  creator       User?                          @relation("emission_factor_dimension_created_by", fields: [createdById], references: [id])
  updater       User?                          @relation("emission_factor_dimension_updated_by", fields: [updatedById], references: [id])
  values        EmissionFactorDimensionValue[]

  @@unique([subcategoryId, code])
  @@unique([subcategoryId, position])
  @@map("emission_factor_dimension")
}

model EmissionFactorDimensionValue {
  id                          BigInt                         @id @default(autoincrement())
  dimensionId                 BigInt                         @map("dimension_id")
  parentValueId               BigInt?                        @map("parent_value_id")
  value                       String
  isActive                    Boolean                        @default(true) @map("is_active")
  createdAt                   DateTime                       @default(now()) @map("created_at")
  updatedAt                   DateTime                       @default(now()) @updatedAt @map("updated_at")
  createdById                 BigInt?                        @map("created_by_id")
  updatedById                 BigInt?                        @map("updated_by_id")
  dimension                   EmissionFactorDimension        @relation(fields: [dimensionId], references: [id])
  parentValue                 EmissionFactorDimensionValue?  @relation("dimension_value_hierarchy", fields: [parentValueId], references: [id])
  childValues                 EmissionFactorDimensionValue[] @relation("dimension_value_hierarchy")
  emissionFactorsAsDimension1 EmissionFactor[]               @relation("emission_factor_dimension_value_1")
  emissionFactorsAsDimension2 EmissionFactor[]               @relation("emission_factor_dimension_value_2")
  lineInputsAsSelection1      CarbonInventoryLineInput[]     @relation("line_input_selection_1")
  lineInputsAsSelection2      CarbonInventoryLineInput[]     @relation("line_input_selection_2")
  creator                     User?                          @relation("emission_factor_dimension_value_created_by", fields: [createdById], references: [id])
  updater                     User?                          @relation("emission_factor_dimension_value_updated_by", fields: [updatedById], references: [id])

  @@unique([dimensionId, value])
  @@map("emission_factor_dimension_value")
}

model EmissionFactor {
  id                    BigInt                        @id @default(autoincrement())
  subcategoryId         BigInt                        @map("subcategory_id")
  dimensionValue1Id     BigInt?                       @map("dimension_value_1_id")
  dimensionValue2Id     BigInt?                       @map("dimension_value_2_id")
  rateMeasurementUnitId BigInt                        @map("rate_measurement_unit_id")
  source                String
  gasDetails            Json                          @map("gas_details") @db.JsonB
  value                 Decimal                       @db.Decimal(18, 10)
  statusId              BigInt                        @map("status_id")
  createdAt             DateTime                      @default(now()) @map("created_at")
  updatedAt             DateTime                      @default(now()) @updatedAt @map("updated_at")
  createdById           BigInt?                       @map("created_by_id")
  updatedById           BigInt?                       @map("updated_by_id")
  subcategory           Subcategory                   @relation(fields: [subcategoryId], references: [id])
  dimensionValue1       EmissionFactorDimensionValue? @relation("emission_factor_dimension_value_1", fields: [dimensionValue1Id], references: [id])
  dimensionValue2       EmissionFactorDimensionValue? @relation("emission_factor_dimension_value_2", fields: [dimensionValue2Id], references: [id])
  rateMeasurementUnit   RateMeasurementUnit           @relation(fields: [rateMeasurementUnitId], references: [id])
  status                StatusCatalog                 @relation(fields: [statusId], references: [id])
  creator               User?                         @relation("emission_factor_created_by", fields: [createdById], references: [id])
  updater               User?                         @relation("emission_factor_updated_by", fields: [updatedById], references: [id])
  lineFactors           CarbonInventoryLineFactor[]

  // TODO: Enforce UNIQUE (subcategory_id, dimension_value_1_id, dimension_value_2_id) WHERE status = 'ACTIVE'

  @@unique([subcategoryId, dimensionValue1Id, dimensionValue2Id, source], map: "emission_factor_unique_subcategory_dims_source")
  @@map("emission_factor")
}

model CarbonInventory {
  id                   BigInt                @id @default(autoincrement())
  organizationId       BigInt?               @map("organization_id")
  organizationBranchId BigInt?               @map("organization_branch_id")
  organizationData     Json?                 @map("organization_data") @db.JsonB
  year                 Int?
  status               InventoryStatus       @default(DRAFT)
  usageMode            UsageMode             @map("usage_mode")
  methodologyVersionId BigInt?               @map("methodology_version_id")
  preselectedNodesId   BigInt?               @map("preselected_nodes_id")
  isEditable           Boolean               @default(true) @map("is_editable")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @default(now()) @updatedAt @map("updated_at")
  createdById          BigInt?               @map("created_by_id")
  updatedById          BigInt?               @map("updated_by_id")
  methodologyVersion   MethodologyVersion?   @relation(fields: [methodologyVersionId], references: [id])
  creator              User?                 @relation("carbon_inventory_created_by", fields: [createdById], references: [id])
  updater              User?                 @relation("carbon_inventory_updated_by", fields: [updatedById], references: [id])
  lines                CarbonInventoryLine[]

  @@map("carbon_inventory")
}

// A "line" represents what is being measured (subcategory + optional selections) for a given inventory.
// We do not store quantities/factors here. It's the anchor.
model CarbonInventoryLine {
  id                BigInt                     @id @default(autoincrement())
  carbonInventoryId BigInt                     @map("carbon_inventory_id")
  subcategoryId     BigInt                     @map("subcategory_id")
  statusId          BigInt                     @map("status_id")
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedAt         DateTime                   @default(now()) @updatedAt @map("updated_at")
  createdById       BigInt?                    @map("created_by_id")
  updatedById       BigInt?                    @map("updated_by_id")
  carbonInventory   CarbonInventory            @relation(fields: [carbonInventoryId], references: [id])
  subcategory       Subcategory                @relation(fields: [subcategoryId], references: [id])
  status            StatusCatalog              @relation(fields: [statusId], references: [id])
  creator           User?                      @relation("carbon_inventory_line_created_by", fields: [createdById], references: [id])
  updater           User?                      @relation("carbon_inventory_line_updated_by", fields: [updatedById], references: [id])
  inputs            CarbonInventoryLineInput[]

  @@map("carbon_inventory_line")
}

model CarbonInventoryLineInput {
  id                     BigInt                        @id @default(autoincrement())
  lineId                 BigInt                        @map("line_id")
  inputType              InputType                     @map("input_type")
  selection1Id           BigInt?                       @map("selection_1_id")
  selection2Id           BigInt?                       @map("selection_2_id")
  quantity               Decimal?                      @db.Decimal(18, 10)
  measurementUnitId      BigInt?                       @map("measurement_unit_id")
  directTotalEmissions   Decimal?                      @map("direct_total_emissions") @db.Decimal(18, 10)
  manualFactor           Decimal?                      @map("manual_factor") @db.Decimal(18, 10)
  manualFactorSource     String?                       @map("manual_factor_source")
  manualFactorRateUnitId BigInt?                       @map("manual_factor_rate_unit_id")
  comment                String?
  isActive               Boolean                       @default(true) @map("is_active")
  createdAt              DateTime                      @default(now()) @map("created_at")
  updatedAt              DateTime                      @default(now()) @updatedAt @map("updated_at")
  createdById            BigInt?                       @map("created_by_id")
  updatedById            BigInt?                       @map("updated_by_id")
  line                   CarbonInventoryLine           @relation(fields: [lineId], references: [id])
  selection1             EmissionFactorDimensionValue? @relation("line_input_selection_1", fields: [selection1Id], references: [id])
  selection2             EmissionFactorDimensionValue? @relation("line_input_selection_2", fields: [selection2Id], references: [id])
  measurementUnit        MeasurementUnit?              @relation(fields: [measurementUnitId], references: [id])
  manualFactorRateUnit   RateMeasurementUnit?          @relation("manual_factor_rate_unit", fields: [manualFactorRateUnitId], references: [id])
  creator                User?                         @relation("carbon_inventory_line_input_created_by", fields: [createdById], references: [id])
  updater                User?                         @relation("carbon_inventory_line_input_updated_by", fields: [updatedById], references: [id])
  factor                 CarbonInventoryLineFactor?
  result                 CarbonInventoryLineResult?

  // Enforced via DB constraint: UNIQUE(line_id) WHERE is_active = true
  // See migration: 20260101235319_add_unique_active_input_per_line_constraint
  @@map("carbon_inventory_line_input")
}

// This stores "what factor did we use, after conversions, and why" so results are reproducible.
// NOTE: appliedFactorValue is required because it represents the normalized factor actually used
// in the computation (post-conversion). For reproducibility of calculations, this value must
// always be present. If a factor cannot be determined at creation time, the creation should
// fail rather than storing NULL, as NULL would break result reproducibility.
model CarbonInventoryLineFactor {
  id                      BigInt                   @id @default(autoincrement())
  lineInputId             BigInt                   @map("line_input_id")
  emissionFactorId        BigInt?                  @map("emission_factor_id")
  appliedFactorValue      Decimal                  @map("applied_factor_value") @db.Decimal(18, 10)
  appliedFactorRateUnitId BigInt                   @map("applied_factor_rate_unit_id")
  appliedFactorSource     String?                  @map("applied_factor_source")
  derivationDetails       Json?                    @map("derivation_details") @db.JsonB
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @default(now()) @updatedAt @map("updated_at")
  createdById             BigInt?                  @map("created_by_id")
  updatedById             BigInt?                  @map("updated_by_id")
  lineInput               CarbonInventoryLineInput @relation(fields: [lineInputId], references: [id])
  emissionFactor          EmissionFactor?          @relation(fields: [emissionFactorId], references: [id])
  appliedFactorRateUnit   RateMeasurementUnit      @relation("applied_factor_rate_unit", fields: [appliedFactorRateUnitId], references: [id])
  creator                 User?                    @relation("carbon_inventory_line_factor_created_by", fields: [createdById], references: [id])
  updater                 User?                    @relation("carbon_inventory_line_factor_updated_by", fields: [updatedById], references: [id])

  @@unique([lineInputId])
  @@map("carbon_inventory_line_factor")
}

model CarbonInventoryLineResult {
  id             BigInt                   @id @default(autoincrement())
  lineInputId    BigInt                   @map("line_input_id")
  totalEmissions Decimal                  @map("total_emissions") @db.Decimal(18, 10)
  resultDetails  Json?                    @map("result_details") @db.JsonB
  calculatedAt   DateTime                 @default(now()) @map("calculated_at")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @default(now()) @updatedAt @map("updated_at")
  createdById    BigInt?                  @map("created_by_id")
  updatedById    BigInt?                  @map("updated_by_id")
  lineInput      CarbonInventoryLineInput @relation(fields: [lineInputId], references: [id])
  creator        User?                    @relation("carbon_inventory_line_result_created_by", fields: [createdById], references: [id])
  updater        User?                    @relation("carbon_inventory_line_result_updated_by", fields: [updatedById], references: [id])

  @@unique([lineInputId])
  @@map("carbon_inventory_line_result")
}
