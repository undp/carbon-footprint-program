  submissionId       BigInt           @unique @map("submission_id")
  type               SubmissionType
  status             SubmissionStatus
  organizationId     BigInt           @map("organization_id")
  organizationName   String           @map("organization_name")
  period             Int?
  requestedAt        DateTime         @map("requested_at")
  carbonInventoryId  BigInt?          @map("carbon_inventory_id")
  reductionProjectId BigInt?          @map("reduction_project_id")
  submission         Submission       @relation(fields: [submissionId], references: [id])

  @@map("submission_summary_view")
}

enum BadgeType {
  ORGANIZATION_ACCREDITATION
  CARBON_INVENTORY_CALCULATION
  CARBON_INVENTORY_VERIFICATION
  REDUCTION_PROJECT_VERIFICATION
  NEUTRALIZATION_PLAN_VERIFICATION

  @@map("badge_type")
}

enum BadgeStatus {
  ACTIVE
  INACTIVE

  @@map("badge_status")
}

model Badge {
  id        BigInt      @id @default(autoincrement())
  type      BadgeType
  status    BadgeStatus @default(ACTIVE)
  fileId    BigInt      @unique @map("file_id")
  createdAt DateTime    @default(now()) @map("created_at")

  file        File         @relation("badge_file", fields: [fileId], references: [id])
  submissions Submission[]

  // Enforced by partial unique index in migration:
  // UNIQUE (type) WHERE status = 'ACTIVE'
  @@map("badge")
}

enum ReductionPlanInitiativeStatus {
  ACTIVE
  DELETED

  @@map("reduction_plan_initiative_status")
}

model ReductionPlanInitiative {
  id                BigInt                        @id @default(autoincrement())
  subcategoryId     BigInt                        @map("subcategory_id")
  dimensionValue1Id BigInt?                       @map("dimension_value_1_id")
  dimensionValue2Id BigInt?                       @map("dimension_value_2_id")
  title             String
  description       String
  status            ReductionPlanInitiativeStatus @default(ACTIVE)
  createdAt         DateTime                      @default(now()) @map("created_at")
  updatedAt         DateTime?                     @updatedAt @map("updated_at")
  createdById       BigInt?                       @map("created_by_id")
  updatedById       BigInt?                       @map("updated_by_id")
  subcategory       Subcategory                   @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  dimensionValue1   EmissionFactorDimensionValue? @relation("reduction_plan_initiative_dimension_value_1", fields: [dimensionValue1Id], references: [id])
  dimensionValue2   EmissionFactorDimensionValue? @relation("reduction_plan_initiative_dimension_value_2", fields: [dimensionValue2Id], references: [id])
  creator           User?                         @relation("reduction_plan_initiative_created_by", fields: [createdById], references: [id])
  updater           User?                         @relation("reduction_plan_initiative_updated_by", fields: [updatedById], references: [id])

  // Partial unique index exists in SQL migration:
  // ("subcategory_id", "title") WHERE status = 'ACTIVE'

  @@map("reduction_plan_initiative")
}
