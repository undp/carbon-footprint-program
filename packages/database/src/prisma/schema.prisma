generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  moduleFormat    = "esm"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}

model Country {
  id                       BigInt                    @id @default(autoincrement())
  name                     String
  isoCode                  String                    @unique @map("iso_code")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime?                 @updatedAt @map("updated_at")
  countryJobPositions      CountryJobPosition[]
  countryOrganizationSizes CountryOrganizationSize[]
  countrySectors           CountrySector[]
  countryParameters        CountryParameter[]
  methodologyVersions      MethodologyVersion[]
  organizations            Organization[]

  @@map("country")
}

model CountryParameter {
  id          BigInt    @id @default(autoincrement())
  countryId   BigInt    @map("country_id")
  key         String
  value       String
  description String
  type        String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  createdById BigInt?   @map("created_by_id")
  updatedById BigInt?   @map("updated_by_id")
  country     Country   @relation(fields: [countryId], references: [id])
  creator     User?     @relation("country_parameter_created_by", fields: [createdById], references: [id])
  updater     User?     @relation("country_parameter_updated_by", fields: [updatedById], references: [id])

  @@unique([countryId, key])
  @@map("country_parameter")
}

model SystemParameter {
  id          BigInt    @id @default(autoincrement())
  key         String    @unique
  value       String
  description String
  type        String
  options     String[]  @default([])
  minValue    Int?      @map("min_value")
  maxValue    Int?      @map("max_value")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  createdById BigInt?   @map("created_by_id")
  updatedById BigInt?   @map("updated_by_id")
  creator     User?     @relation("system_parameter_created_by", fields: [createdById], references: [id])
  updater     User?     @relation("system_parameter_updated_by", fields: [updatedById], references: [id])

  @@map("system_parameter")
}

enum CountryOrganizationSizeStatus {
  ACTIVE
  DELETED

  @@map("country_organization_size_status")
}

model CountryOrganizationSize {
  id               BigInt                        @id @default(autoincrement())
  countryId        BigInt                        @map("country_id")
  name             String
  description      String?
  // Position must be > 0 (enforced by DB CHECK constraint: country_organization_size_position_check)
  position         Int
  status           CountryOrganizationSizeStatus @default(ACTIVE)
  createdAt        DateTime                      @default(now()) @map("created_at")
  updatedAt        DateTime?                     @updatedAt @map("updated_at")
  createdById      BigInt?                       @map("created_by_id")
  updatedById      BigInt?                       @map("updated_by_id")
  country          Country                       @relation(fields: [countryId], references: [id])
  creator          User?                         @relation("country_organization_size_created_by", fields: [createdById], references: [id])
  updater          User?                         @relation("country_organization_size_updated_by", fields: [updatedById], references: [id])
  organizationData OrganizationData[]

  // NOTE: Partial unique index (countryId, name) WHERE status = 'ACTIVE'.
  // NOTE: Partial unique index (countryId, position) WHERE status <> 'DELETED' enforces unique manual ordering.
  // Both declared in raw SQL in the migration; Prisma does not track partial indexes on schema diffs.
  @@map("country_organization_size")
}

enum CountrySectorStatus {
  ACTIVE
  DELETED

  @@map("country_sector_status")
}

model CountrySector {
  id                         BigInt                      @id @default(autoincrement())
  countryId                  BigInt                      @map("country_id")
  name                       String
  description                String?
  status                     CountrySectorStatus         @default(ACTIVE)
  createdAt                  DateTime                    @default(now()) @map("created_at")
  updatedAt                  DateTime?                   @updatedAt @map("updated_at")
  createdById                BigInt?                     @map("created_by_id")
  updatedById                BigInt?                     @map("updated_by_id")
  country                    Country                     @relation(fields: [countryId], references: [id])
  creator                    User?                       @relation("country_sector_created_by", fields: [createdById], references: [id])
  updater                    User?                       @relation("country_sector_updated_by", fields: [updatedById], references: [id])
  subsectors                 CountrySubsector[]
  organizationMainActivities OrganizationMainActivity[]
  organizationData           OrganizationData[]
  subcategoryRecommendations SubcategoryRecommendation[]

  // NOTE: Partial unique index (countryId, name) WHERE status = 'ACTIVE'.
  // Declared in raw SQL in the migration; Prisma does not track partial indexes on schema diffs.
  // Preserve the WHERE clause manually when touching this table.
  @@map("country_sector")
}

enum CountrySubsectorStatus {
  ACTIVE
  DELETED

  @@map("country_subsector_status")
}

model CountrySubsector {
  id                         BigInt                      @id @default(autoincrement())
  countrySectorId            BigInt                      @map("country_sector_id")
  name                       String
  description                String?
  status                     CountrySubsectorStatus      @default(ACTIVE)
  createdAt                  DateTime                    @default(now()) @map("created_at")
  updatedAt                  DateTime?                   @updatedAt @map("updated_at")
  createdById                BigInt?                     @map("created_by_id")
  updatedById                BigInt?                     @map("updated_by_id")
  countrySector              CountrySector               @relation(fields: [countrySectorId], references: [id])
  creator                    User?                       @relation("country_subsector_created_by", fields: [createdById], references: [id])
  updater                    User?                       @relation("country_subsector_updated_by", fields: [updatedById], references: [id])
  organizationMainActivities OrganizationMainActivity[]
  organizationData           OrganizationData[]
  subcategoryRecommendations SubcategoryRecommendation[]

  // NOTE: Partial unique index (countrySectorId, name) WHERE status = 'ACTIVE'.
  // Declared in raw SQL in the migration; Prisma does not track partial indexes on schema diffs.
  // Preserve the WHERE clause manually when touching this table.
  @@map("country_subsector")
}

enum OrganizationMainActivityStatus {
  ACTIVE
  DELETED

  @@map("organization_main_activity_status")
}

model OrganizationMainActivity {
  id                 BigInt                         @id @default(autoincrement())
  name               String
  description        String?
  status             OrganizationMainActivityStatus @default(ACTIVE)
  countrySectorId    BigInt?                        @map("country_sector_id")
  countrySubsectorId BigInt?                        @map("country_subsector_id")
  createdAt          DateTime                       @default(now()) @map("created_at")
  updatedAt          DateTime?                      @updatedAt @map("updated_at")
  createdById        BigInt?                        @map("created_by_id")
  updatedById        BigInt?                        @map("updated_by_id")
  countrySector      CountrySector?                 @relation(fields: [countrySectorId], references: [id])
  countrySubsector   CountrySubsector?              @relation(fields: [countrySubsectorId], references: [id])
  creator            User?                          @relation("organization_main_activity_created_by", fields: [createdById], references: [id])
  updater            User?                          @relation("organization_main_activity_updated_by", fields: [updatedById], references: [id])
  organizationData   OrganizationData[]

  // NOTE: Partial unique index (name, countrySectorId, countrySubsectorId) NULLS NOT DISTINCT WHERE status = 'ACTIVE'.
  // Declared in raw SQL in the migration; Prisma does not track partial indexes on schema diffs.
  // Preserve the WHERE clause manually when touching this table.
  @@map("organization_main_activity")
}

model CountryJobPosition {
  id               BigInt             @id @default(autoincrement())
  countryId        BigInt             @map("country_id")
  name             String
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime?          @updatedAt @map("updated_at")
  country          Country            @relation(fields: [countryId], references: [id])
  users            User[]
  organizationData OrganizationData[]

  @@unique([countryId, name])
  @@map("country_job_position")
}

enum SystemRole {
  USER
  ADMIN
  SUPERADMIN

  @@map("system_role")
}

enum OrganizationRole {
  VIEWER
  CONTRIBUTOR
  ADMIN

  @@map("organization_role")
}

enum MembershipStatus {
  ACTIVE
  OUTDATED
  DELETED

  @@map("membership_status")
}

enum SubcategoryStatus {
  ACTIVE
  DELETED

  @@map("subcategory_status")
}

enum EmissionFactorDimensionStatus {
  ACTIVE
  DELETED

  @@map("emission_factor_dimension_status")
}

enum EmissionFactorDimensionValueStatus {
  ACTIVE
  DELETED

  @@map("emission_factor_dimension_value_status")
}

model UserOrganizationMembership {
  id             BigInt           @id @default(autoincrement())
  userId         BigInt           @map("user_id")
  organizationId BigInt           @map("organization_id")
  role           OrganizationRole @default(VIEWER)
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime?        @updatedAt @map("updated_at")
  createdById    BigInt?          @map("created_by_id")
  updatedById    BigInt?          @map("updated_by_id")

  user         User         @relation("user_memberships", fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  creator      User?        @relation("membership_created_by", fields: [createdById], references: [id])
  updater      User?        @relation("membership_updated_by", fields: [updatedById], references: [id])

  @@index([userId, organizationId])
  @@map("user_organization_membership")
}

model User {
  id                                   BigInt                         @id @default(autoincrement())
  uuid                                 String                         @unique @default(uuid()) @db.Uuid
  idpUserId                            String?                        @unique @map("idp_user_id")
  idpName                              String?                        @map("idp_name")
  email                                String?                        @unique
  role                                 SystemRole                     @default(USER)
  countryJobPositionId                 BigInt?                        @map("country_job_position_id")
  firstName                            String?                        @map("first_name")
  lastName                             String?                        @map("last_name")
  createdAt                            DateTime                       @default(now()) @map("created_at")
  updatedAt                            DateTime?                      @updatedAt @map("updated_at")
  createdById                          BigInt?                        @map("created_by_id")
  updatedById                          BigInt?                        @map("updated_by_id")
  termsAccepted                        Boolean                        @default(false) @map("terms_accepted")
  termsAcceptedAt                      DateTime?                      @map("terms_accepted_at")
  lastAccessAt                         DateTime?                      @map("last_access_at")
  countryParametersCreated             CountryParameter[]             @relation("country_parameter_created_by")
  countryParametersUpdated             CountryParameter[]             @relation("country_parameter_updated_by")
  countryOrganizationSizesCreated      CountryOrganizationSize[]      @relation("country_organization_size_created_by")
  countryOrganizationSizesUpdated      CountryOrganizationSize[]      @relation("country_organization_size_updated_by")
  countrySectorsCreated                CountrySector[]                @relation("country_sector_created_by")
  countrySectorsUpdated                CountrySector[]                @relation("country_sector_updated_by")
  countrySubsectorsCreated             CountrySubsector[]             @relation("country_subsector_created_by")
  countrySubsectorsUpdated             CountrySubsector[]             @relation("country_subsector_updated_by")
  organizationMainActivitiesCreated    OrganizationMainActivity[]     @relation("organization_main_activity_created_by")
  organizationMainActivitiesUpdated    OrganizationMainActivity[]     @relation("organization_main_activity_updated_by")
  systemParametersCreated              SystemParameter[]              @relation("system_parameter_created_by")
  systemParametersUpdated              SystemParameter[]              @relation("system_parameter_updated_by")
  carbonInventoriesCreated             CarbonInventory[]              @relation("carbon_inventory_created_by")
  carbonInventoriesUpdated             CarbonInventory[]              @relation("carbon_inventory_updated_by")
  carbonInventoriesSelfDeclared        CarbonInventory[]              @relation("carbon_inventory_self_declared_by")
  reductionProjectsCreated             ReductionProject[]             @relation("reduction_project_created_by")
  reductionProjectsUpdated             ReductionProject[]             @relation("reduction_project_updated_by")
  methodologyVersionsCreated           MethodologyVersion[]           @relation("methodology_version_created_by")
  methodologyVersionsUpdated           MethodologyVersion[]           @relation("methodology_version_updated_by")
  categoriesCreated                    Category[]                     @relation("category_created_by")
  categoriesUpdated                    Category[]                     @relation("category_updated_by")
  subcategoriesCreated                 Subcategory[]                  @relation("subcategory_created_by")
  subcategoriesUpdated                 Subcategory[]                  @relation("subcategory_updated_by")
  subcategoryRecommendationsCreated    SubcategoryRecommendation[]    @relation("subcategory_recommendation_created_by")
  subcategoryRecommendationsUpdated    SubcategoryRecommendation[]    @relation("subcategory_recommendation_updated_by")
  emissionFactorDimensionsCreated      EmissionFactorDimension[]      @relation("emission_factor_dimension_created_by")
  emissionFactorDimensionsUpdated      EmissionFactorDimension[]      @relation("emission_factor_dimension_updated_by")
  emissionFactorDimensionValuesCreated EmissionFactorDimensionValue[] @relation("emission_factor_dimension_value_created_by")
  emissionFactorDimensionValuesUpdated EmissionFactorDimensionValue[] @relation("emission_factor_dimension_value_updated_by")
  emissionFactorsCreated               EmissionFactor[]               @relation("emission_factor_created_by")
  emissionFactorsUpdated               EmissionFactor[]               @relation("emission_factor_updated_by")
  carbonInventoryLinesCreated          CarbonInventoryLine[]          @relation("carbon_inventory_line_created_by")
  carbonInventoryLinesUpdated          CarbonInventoryLine[]          @relation("carbon_inventory_line_updated_by")
  carbonInventoryLineFilesCreated      CarbonInventoryLineFile[]      @relation("carbon_inventory_line_file_created_by")
  carbonInventoryLineInputsCreated     CarbonInventoryLineInput[]     @relation("carbon_inventory_line_input_created_by")
  carbonInventoryLineInputsUpdated     CarbonInventoryLineInput[]     @relation("carbon_inventory_line_input_updated_by")
  carbonInventoryLineFactorsCreated    CarbonInventoryLineFactor[]    @relation("carbon_inventory_line_factor_created_by")
  carbonInventoryLineFactorsUpdated    CarbonInventoryLineFactor[]    @relation("carbon_inventory_line_factor_updated_by")
  carbonInventoryLineResultsCreated    CarbonInventoryLineResult[]    @relation("carbon_inventory_line_result_created_by")
  carbonInventoryLineResultsUpdated    CarbonInventoryLineResult[]    @relation("carbon_inventory_line_result_updated_by")
  countryJobPosition                   CountryJobPosition?            @relation(fields: [countryJobPositionId], references: [id])
  creator                              User?                          @relation("user_created_by", fields: [createdById], references: [id])
  usersCreated                         User[]                         @relation("user_created_by")
  updater                              User?                          @relation("user_updated_by", fields: [updatedById], references: [id])
  usersUpdated                         User[]                         @relation("user_updated_by")
  organizationsCreated                 Organization[]                 @relation("organization_created_by")
  organizationsUpdated                 Organization[]                 @relation("organization_updated_by")
  organizationsDataCreated             OrganizationData[]             @relation("organization_data_created_by")
  organizationsDataUpdated             OrganizationData[]             @relation("organization_data_updated_by")
  submissionSubjectsCreated            SubmissionSubject[]            @relation("submission_subject_created_by")
  submissionsReviewed                  Submission[]                   @relation("submission_reviewer")
  submissionsCreated                   Submission[]                   @relation("submission_created_by")
  submissionsUpdated                   Submission[]                   @relation("submission_updated_by")
  memberships                          UserOrganizationMembership[]   @relation("user_memberships")
  membershipsCreated                   UserOrganizationMembership[]   @relation("membership_created_by")
  membershipsUpdated                   UserOrganizationMembership[]   @relation("membership_updated_by")
  filesUploaded                        File[]                         @relation("file_created_by")
  explanationsCreated                  Explanation[]                  @relation("explanation_created_by")
  explanationsUpdated                  Explanation[]                  @relation("explanation_updated_by")
  reductionPlanInitiativesCreated      ReductionPlanInitiative[]      @relation("reduction_plan_initiative_created_by")
  reductionPlanInitiativesUpdated      ReductionPlanInitiative[]      @relation("reduction_plan_initiative_updated_by")
  roleAuditAsTarget                    UserRoleAudit[]                @relation("user_role_audit_target")
  roleAuditAsActor                     UserRoleAudit[]                @relation("user_role_audit_actor")
  accessLogs                           UserAccessLog[]

  @@map("user")
}

model UserRoleAudit {
  id           BigInt     @id @default(autoincrement())
  userId       BigInt     @map("user_id")
  previousRole SystemRole @map("previous_role")
  newRole      SystemRole @map("new_role")
  changedById  BigInt     @map("changed_by_id")
  createdAt    DateTime   @default(now()) @map("created_at")

  user      User @relation("user_role_audit_target", fields: [userId], references: [id], onDelete: Restrict)
  changedBy User @relation("user_role_audit_actor", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@map("user_role_audit")
}

model UserAccessLog {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("user_access_log")
}

enum MagnitudeStatus {
  ACTIVE
  DELETED

  @@map("magnitude_status")
}

model Magnitude {
  id        BigInt          @id @default(autoincrement())
  code      String          @unique
  name      String
  isSystem  Boolean         @default(false) @map("is_system")
  status    MagnitudeStatus @default(ACTIVE)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  measurementUnits MeasurementUnit[]

  @@map("magnitude")
}

enum MeasurementUnitStatus {
  ACTIVE
  DELETED

  @@map("measurement_unit_status")
}

model MeasurementUnit {
  id                          BigInt                       @id @default(autoincrement())
  name                        String
  magnitudeId                 BigInt                       @map("magnitude_id")
  abbreviation                String                       @unique
  baseFactor                  Float                        @map("base_factor")
  isBase                      Boolean                      @map("is_base")
  status                      MeasurementUnitStatus        @default(ACTIVE)
  magnitude                   Magnitude                    @relation(fields: [magnitudeId], references: [id], onDelete: Restrict)
  rateUnitsAsDenominator      RateMeasurementUnit[]        @relation("denominator_measurement_unit")
  rateUnitsAsNumerator        RateMeasurementUnit[]        @relation("numerator_measurement_unit")
  lineInputs                  CarbonInventoryLineInput[]
  subcategoryMeasurementUnits SubcategoryMeasurementUnit[]

  @@index([magnitudeId])
  @@map("measurement_unit")
}

model RateMeasurementUnit {
  id                           BigInt                      @id @default(autoincrement())
  name                         String
  abbreviation                 String                      @unique
  numeratorMeasurementUnitId   BigInt                      @map("numerator_measurement_unit_id")
  denominatorMeasurementUnitId BigInt                      @map("denominator_measurement_unit_id")
  status                       MeasurementUnitStatus       @default(ACTIVE)
  denominatorMeasurementUnit   MeasurementUnit             @relation("denominator_measurement_unit", fields: [denominatorMeasurementUnitId], references: [id])
  numeratorMeasurementUnit     MeasurementUnit             @relation("numerator_measurement_unit", fields: [numeratorMeasurementUnitId], references: [id])
  emissionFactors              EmissionFactor[]
  lineInputsAsManualFactor     CarbonInventoryLineInput[]  @relation("manual_factor_rate_unit")
  lineFactorsAsApplied         CarbonInventoryLineFactor[] @relation("applied_factor_rate_unit")

  @@map("rate_measurement_unit")
}

enum MethodologyVersionStatus {
  PUBLISHED
  UNPUBLISHED
  DELETED

  @@map("methodology_version_status")
}

enum CategoryStatus {
  ACTIVE
  DELETED

  @@map("category_status")
}

model MethodologyVersion {
  id                BigInt                   @id @default(autoincrement())
  countryId         BigInt                   @map("country_id")
  name              String
  description       String
  regulation        String
  version           String
  status            MethodologyVersionStatus
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime?                @updatedAt @map("updated_at")
  createdById       BigInt?                  @map("created_by_id")
  updatedById       BigInt?                  @map("updated_by_id")
  country           Country                  @relation(fields: [countryId], references: [id])
  creator           User?                    @relation("methodology_version_created_by", fields: [createdById], references: [id])
  updater           User?                    @relation("methodology_version_updated_by", fields: [updatedById], references: [id])
  categories        Category[]
  carbonInventories CarbonInventory[]

  // Partial unique index exists in SQL migrations:
  // ("country_id", "name") WHERE status <> 'DELETED'
  // TODO: Enforce via trigger at most 1 active per country
  // TODO: Enforce somehow country's active_methodology_version_id must point to ACTIVE

  @@map("methodology_version")
}

model Explanation {
  slug        String    @id
  name        String
  description String?
  content     String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  createdById BigInt?   @map("created_by_id")
  updatedById BigInt?   @map("updated_by_id")
  creator     User?     @relation("explanation_created_by", fields: [createdById], references: [id])
  updater     User?     @relation("explanation_updated_by", fields: [updatedById], references: [id])

  @@map("explanation")
}

model Category {
  id                   BigInt             @id @default(autoincrement())
  methodologyVersionId BigInt             @map("methodology_version_id")
  name                 String
  icon                 String
  color                String
  synonyms             String
  description          String
  explanation          String?            @db.Text
  // Position must be > 0 (enforced by DB CHECK constraint: category_position_check)
  position             Int
  status               CategoryStatus     @default(ACTIVE)
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime?          @updatedAt @map("updated_at")
  createdById          BigInt?            @map("created_by_id")
  updatedById          BigInt?            @map("updated_by_id")
  methodologyVersion   MethodologyVersion @relation(fields: [methodologyVersionId], references: [id], onDelete: Cascade)
  creator              User?              @relation("category_created_by", fields: [createdById], references: [id])
  updater              User?              @relation("category_updated_by", fields: [updatedById], references: [id])
  subcategories        Subcategory[]

  // Partial unique indexes exist in SQL migrations:
  // ("methodology_version_id", "name") WHERE status <> 'DELETED'
  // ("methodology_version_id", "position") WHERE status <> 'DELETED'

  @@map("category")
}

model Subcategory {
  id                          BigInt                       @id @default(autoincrement())
  categoryId                  BigInt                       @map("category_id")
  name                        String
  icon                        String
  description                 String
  explanation                 String?                      @db.Text
  status                      SubcategoryStatus            @default(ACTIVE)
  createdAt                   DateTime                     @default(now()) @map("created_at")
  updatedAt                   DateTime?                    @updatedAt @map("updated_at")
  createdById                 BigInt?                      @map("created_by_id")
  updatedById                 BigInt?                      @map("updated_by_id")
  category                    Category                     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  creator                     User?                        @relation("subcategory_created_by", fields: [createdById], references: [id])
  updater                     User?                        @relation("subcategory_updated_by", fields: [updatedById], references: [id])
  dimensions                  EmissionFactorDimension[]
  emissionFactors             EmissionFactor[]
  inventoryLines              CarbonInventoryLine[]
  subcategoryMeasurementUnits SubcategoryMeasurementUnit[]
  recommendations             SubcategoryRecommendation[]
  reductionPlanInitiatives    ReductionPlanInitiative[]
  reductionProjects           ReductionProject[]           @relation("reduction_project_subcategory")

  // Partial unique index exists in SQL migration:
  // ("category_id", "name") WHERE status <> 'DELETED'

  @@map("subcategory")
}

model SubcategoryMeasurementUnit {
  id                BigInt          @id @default(autoincrement())
  subcategoryId     BigInt          @map("subcategory_id")
  measurementUnitId BigInt          @map("measurement_unit_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  subcategory       Subcategory     @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  measurementUnit   MeasurementUnit @relation(fields: [measurementUnitId], references: [id])

  @@unique([subcategoryId, measurementUnitId])
  @@map("subcategory_measurement_unit")
}

enum SubcategoryRecommendationStatus {
  ACTIVE
  DELETED

  @@map("subcategory_recommendation_status")
}

model SubcategoryRecommendation {
  id            BigInt                          @id @default(autoincrement())
  subcategoryId BigInt                          @map("subcategory_id")
  sectorId      BigInt                          @map("sector_id")
  subsectorId   BigInt?                         @map("subsector_id")
  status        SubcategoryRecommendationStatus @default(ACTIVE)
  createdAt     DateTime                        @default(now()) @map("created_at")
  updatedAt     DateTime?                       @updatedAt @map("updated_at")
  createdById   BigInt?                         @map("created_by_id")
  updatedById   BigInt?                         @map("updated_by_id")
  subcategory   Subcategory                     @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  sector        CountrySector                   @relation(fields: [sectorId], references: [id])
  subsector     CountrySubsector?               @relation(fields: [subsectorId], references: [id])
  creator       User?                           @relation("subcategory_recommendation_created_by", fields: [createdById], references: [id])
  updater       User?                           @relation("subcategory_recommendation_updated_by", fields: [updatedById], references: [id])

  // Partial unique index exists in SQL migration:
  // ("subcategory_id", "sector_id", "subsector_id") WHERE status = 'ACTIVE'

  @@map("subcategory_recommendation")
}

model EmissionFactorDimension {
  id            BigInt                         @id @default(autoincrement())
  subcategoryId BigInt                         @map("subcategory_id")
  code          String
  name          String
  // Position must be > 0 (enforced by DB CHECK constraint: emission_factor_dimension_position_check)
  position      Int
  isRequired    Boolean                        @map("is_required")
  status        EmissionFactorDimensionStatus  @default(ACTIVE)
  createdAt     DateTime                       @default(now()) @map("created_at")
  updatedAt     DateTime?                      @updatedAt @map("updated_at")
  createdById   BigInt?                        @map("created_by_id")
  updatedById   BigInt?                        @map("updated_by_id")
