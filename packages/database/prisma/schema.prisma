generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model user {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model book {
  id        Int           @id @default(autoincrement())
  title     String        @unique
  author    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  history   bookHistory[]
}

model bookHistory {
  id        Int      @id @default(autoincrement())
  bookId    Int
  action    String
  createdAt DateTime @default(now())
  book      book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
}
