{
  "name": "@repo/database",
  "version": "0.0.0",
  "description": "Database package for the Huella Latam project",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./enums": {
      "types": "./dist/enums.d.ts",
      "default": "./dist/enums.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prebuild": "prisma generate",
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json && cpy \"src/generated/prisma/**\" dist/generated/prisma",
    "lint": "eslint .",
    "dev:generate": "prisma generate",
    "dev:migrate": "prisma migrate dev",
    "dev:studio": "prisma studio",
    "db:restore": "prisma migrate reset --force",
    "prod:deploy": "prisma migrate deploy",
    "clean": "rimraf dist tsconfig.build.tsbuildinfo .turbo",
    "validate:version": "tsx scripts/validate-postgres-version.ts",
    "promote-superadmin": "tsx src/scripts/promote-superadmin.ts",
    "db:drop:worktree": "tsx src/scripts/drop-worktree-database.ts"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@types/node": "catalog:shared",
    "eslint": "catalog:shared",
    "prisma": "^7.8.0",
    "rimraf": "catalog:shared",
    "tsx": "catalog:shared",
    "typescript": "catalog:shared"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0"
  }
}
