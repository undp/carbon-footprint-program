{
  "name": "@repo/database",
  "version": "0.0.0",
  "description": "Database package for the Huella Latam project",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
    "prebuild": "prisma generate",
    "build": "rimraf dist && tsc -p tsconfig.build.json && cpy generated dist --flat=false",
    "clean": "rimraf dist",
    "dev:generate": "prisma generate",
    "dev:migrate": "prisma migrate dev",
    "dev:seed": "prisma db seed",
    "dev:studio": "prisma studio",
    "dev:reset": "prisma migrate reset",
    "prod:deploy": "prisma migrate deploy",
    "validate:version": "tsx validate-postgres-version.ts"
  },
  "devDependencies": {
    "@types/node": "catalog:shared",
    "prisma": "^7.0.1",
    "tsx": "catalog:shared",
    "typescript": "catalog:shared"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "@prisma/client-runtime-utils": "^7.0.1"
  }
}
