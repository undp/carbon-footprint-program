{
  "name": "@repo/database",
  "version": "0.0.0",
  "description": "Database package for the Huella Latam project",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./enums": {
      "types": "./dist/enums.d.ts",
      "default": "./dist/enums.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prebuild": "prisma generate --config=prisma.config.pg.ts",
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json && cpy \"src/generated/prisma/**\" dist/generated/prisma",
    "lint": "eslint .",
    "dev:generate:pg": "prisma generate --config=prisma.config.pg.ts",
    "dev:generate:mssql": "prisma generate --config=prisma.config.mssql.ts",
    "dev:migrate:pg": "prisma migrate dev --config=prisma.config.pg.ts",
    "dev:migrate:mssql": "prisma migrate dev --config=prisma.config.mssql.ts",
    "dev:seed:pg": "DB_PROVIDER=postgresql prisma db seed --config=prisma.config.pg.ts",
    "dev:seed:mssql": "DB_PROVIDER=sqlserver prisma db seed --config=prisma.config.mssql.ts",
    "dev:studio": "prisma studio --config=prisma.config.pg.ts",
    "db:restore": "prisma migrate reset --force --config=prisma.config.pg.ts && pnpm dev:seed:pg",
    "prod:deploy:pg": "prisma migrate deploy --config=prisma.config.pg.ts",
    "prod:deploy:mssql": "prisma migrate deploy --config=prisma.config.mssql.ts",
    "dev:generate": "pnpm dev:generate:pg",
    "dev:migrate": "pnpm dev:migrate:pg",
    "dev:seed": "pnpm dev:seed:pg",
    "prod:deploy": "pnpm prod:deploy:pg",
    "clean": "rimraf dist tsconfig.build.tsbuildinfo .turbo",
    "validate:version": "tsx scripts/validate-postgres-version.ts",
    "promote-superadmin": "tsx src/scripts/promote-superadmin.ts"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@types/node": "catalog:shared",
    "eslint": "catalog:shared",
    "prisma": "^7.8.0",
    "rimraf": "catalog:shared",
    "tsx": "catalog:shared",
    "typescript": "catalog:shared"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@azure/storage-blob": "^12.31.0",
    "@prisma/adapter-mssql": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@repo/constants": "workspace:*",
    "zod": "catalog:shared"
  }
}
