{
  "extends": "./tsconfig.json",
  "include": ["src"],
  "exclude": ["src/scripts"],
  "compilerOptions": {
    "noEmit": false,
    "composite": false,
    "incremental": false,
    "emitDeclarationOnly": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "stripInternal": true
  }
}
