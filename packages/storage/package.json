{
  "name": "@repo/storage",
  "version": "0.0.0",
  "description": "Object storage package for the Huella Latam project",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./src/testing.ts",
      "import": "./dist/testing.js"
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "type-check": "tsc --noEmit --project tsconfig.build.json",
    "clean": "rimraf dist tsconfig.build.tsbuildinfo .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.33.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:shared",
    "eslint": "catalog:shared",
    "rimraf": "catalog:shared",
    "typescript": "catalog:shared"
  }
}
