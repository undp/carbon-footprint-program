{
  "name": "@repo/constants",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "type-check": "tsc --noEmit --project tsconfig.build.json",
    "clean": "rimraf dist tsconfig.build.tsbuildinfo .turbo"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:shared",
    "eslint": "catalog:shared",
    "rimraf": "catalog:shared",
    "typescript": "catalog:shared"
  }
}
